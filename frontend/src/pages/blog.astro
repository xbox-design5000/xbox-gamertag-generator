---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import { client } from "../lib/sanity";
import { POSTS_QUERY } from "../lib/queries";
import { urlFor } from "../lib/sanity";

const sanityPosts = await client.fetch(POSTS_QUERY);


console.log('Project ID:', import.meta.env.PUBLIC_SANITY_PROJECT_ID);
console.log('Posts fetched:', sanityPosts.length);
console.log('Post titles:', sanityPosts.map((p: any) => p.title));

const blogPosts = sanityPosts.map((post: any) => ({
  id: post.slug,
  title: post.title,
  excerpt: post.excerpt ?? '',
  readTime: post.readingTime ? `${post.readingTime} min read` : '5 min read',
slug: post.slug,
  coverImage: post.featuredImage ? urlFor(post.featuredImage).width(600).height(400).fit('crop').auto('format').url() : null,
}));

const postsPerPage = 6;
const totalPages = Math.max(1, Math.ceil(blogPosts.length / postsPerPage));

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Xbox Gamertag Blog",
  "url": "https://xboxgamertaggenerator.com/blog",
  "description": "Xbox gamertag tips, name ideas, guides, and gaming articles to help you choose better Xbox names.",
  "inLanguage": "en-US",
  "publisher": {
    "@type": "Organization",
    "name": "Xbox Gamertag Generator",
    "url": "https://xboxgamertaggenerator.com"
  }
};
---

<MainLayout
  title="Xbox Gamertag Blog – Tips, Ideas & Guides for Better Xbox Names"
  description="Browse Xbox gamertag tips, creative name ideas, and gaming guides to help you choose a better Xbox name and build a stronger gamer identity."
  canonical="https://xboxgamertaggenerator.com/blog"
  {schema}
>
  <Header />

  <div class="min-h-screen">
    
  <!-- Hero -->
<section class="section-dark-alt py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12 2xl:px-16">
    <section class="bg-card py-16 rounded-lg">
      <div class="px-6 text-center">
        <h1 class="font-ui text-3xl md:text-4xl font-bold mb-4 text-foreground">
          Xbox Naming Tips, <span class="text-brand">Guides</span> &amp; Strategies
        </h1>

        <p class="font-ui text-lg md:text-xl text-foreground-muted mb-4 max-w-3xl mx-auto">
          Everything you need to create, manage, and master your Xbox gamertag.
        </p>

        <p class="font-ui text-base text-foreground-muted max-w-2xl mx-auto">
          Explore in-depth guides, naming trends, and branding strategies to make your gamer identity stand out.
        </p>
      </div>
    </section>
  </div>
</section>

    <!-- Search -->
    <section class="section-white py-12 border-b border-[#E5E7EB]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 md:px-8">
        <div class="text-center mb-8">
          <h2 class="font-ui text-2xl md:text-3xl font-bold text-[#111827]">
            Tips, Guides &amp; Articles
          </h2>
          <p class="font-ui text-sm md:text-base text-[#64748B] mt-2">
            Search through our latest Xbox gamertag articles and guides.
          </p>
        </div>

        <div class="flex flex-col sm:flex-row gap-3 items-center">
          <div class="relative flex-1 w-full">
            <svg
              class="absolute left-3 top-1/2 -translate-y-1/2 text-[#9CA3AF] h-4 w-4"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
            </svg>

            <input
              id="searchInput"
              type="text"
              placeholder="Search for articles..."
              class="w-full h-11 pl-10 pr-4 bg-white border border-[#E5E7EB] rounded-lg font-ui text-sm text-[#111827] placeholder-[#9CA3AF] focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
            />
          </div>

         <button
  id="searchBtn"
  class="w-full sm:w-auto px-6 py-3 bg-brand hover:bg-brand-light text-white font-semibold rounded-lg transition-colors font-ui"
>
  Search
</button>
        </div>

      </div>
    </section>

  <!-- Articles Grid -->
<section class="pt-8 pb-16 section-white-subtle">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-12">
    <h2 id="sectionTitle" class="font-ui text-3xl font-bold text-center mb-6 text-gray-800">
      Latest Articles
    </h2>

    <div id="resultsHeader" class="hidden items-center justify-between mb-6">
      <h2 id="resultsTitle" class="font-ui text-3xl font-bold text-gray-800"></h2>
      <button
        id="clearBtn"
        class="text-brand hover:underline font-ui"
      >
        Clear Search
      </button>
    </div>

    <div id="noResults" class="hidden text-center py-12">
      <p id="noResultsMsg" class="text-xl text-gray-600 mb-4 font-ui"></p>
      <p class="text-gray-500 font-ui">
        Try searching with different keywords or browse our latest articles below.
      </p>
      <button
        id="viewAllBtn"
        class="mt-4 px-6 py-2 bg-brand text-white rounded-lg hover:bg-brand-light transition-colors font-ui"
      >
        View All Articles
      </button>
    </div>

    <div
      id="blogGrid"
      class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      data-posts={JSON.stringify(blogPosts)}
    >
    {blogPosts.slice(0, postsPerPage).map((post) => (
  <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300">
    {post.coverImage
      ? <img src={post.coverImage} alt={post.title} class="w-full h-40 object-cover" />
      : <div class="w-full h-40 bg-gray-300 flex items-center justify-center">
          <span class="text-gray-500 text-sm font-ui">Gaming Image Placeholder</span>
        </div>
    }
    <div class="p-4">
      <a href={`/${post.slug}`} class="block group">
        <h3 class="text-lg font-semibold mb-2 text-gray-800 font-ui line-clamp-2 group-hover:text-brand transition-colors">
          {post.title}
        </h3>
      </a>
      <p class="text-gray-600 mb-3 text-sm font-ui line-clamp-4">
        {post.excerpt}
      </p>
      
      <a  href={`/${post.slug}`}
        class="text-brand font-medium hover:underline inline-flex items-center font-ui mt-auto"
        aria-label={`Read more about ${post.title}`}
      >
        <span>Read more</span>
        <span class="sr-only"> about {post.title}</span>
        <svg class="ml-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </article>
))}
    </div>
  </div>
</section>

<!-- Pagination -->
<section class="section-white-subtle pb-10">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-12">
    <div
      id="paginationWrap"
      class="flex justify-center items-center gap-2 sm:gap-3"
      data-posts-per-page={postsPerPage}
    >
      <button
        id="prevPageBtn"
        class="flex items-center gap-1.5 px-4 py-2 bg-white border border-[#E5E7EB] text-[#6B7280] font-ui text-xs font-bold uppercase tracking-wide rounded transition-all duration-150 hover:border-[#00D02B]/40 hover:text-[#00B324] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:border-[#E5E7EB] disabled:hover:text-[#6B7280]"
      >
        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
        </svg>
        Prev
      </button>

      <div id="pageNumbers" class="flex gap-1.5"></div>

      <button
        id="nextPageBtn"
        class="flex items-center gap-1.5 px-4 py-2 bg-white border border-[#E5E7EB] text-[#6B7280] font-ui text-xs font-bold uppercase tracking-wide rounded transition-all duration-150 hover:border-[#00D02B]/40 hover:text-[#00B324] disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:border-[#E5E7EB] disabled:hover:text-[#6B7280]"
      >
        Next
        <svg class="h-3.5 w-3.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Bottom Ad -->
<section class="section-white-subtle py-12">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-12">
    <div class="bg-white border border-dashed border-[#D1D5DB] rounded-lg px-5 py-4 text-center">
      <p class="font-ui text-[10px] font-bold tracking-[3px] uppercase text-[#94A3B8] mb-3">
        Advertisement
      </p>
      <div class="bg-[#E5E7EB] rounded h-24 md:h-32 lg:h-48"></div>
    </div>
  </div>
</section>

  </div>

<script>
 type Post = {
  id: string;
  title: string;
  excerpt: string;
  readTime: string;
  slug: string;
  coverImage?: string | null;
};

  
  function setupBlogPage() {
    const gridEl = document.getElementById("blogGrid");
  const sectionTitleEl = document.getElementById("sectionTitle");
  const resultsHeaderEl = document.getElementById("resultsHeader");
  const resultsTitleEl = document.getElementById("resultsTitle");
  const noResultsEl = document.getElementById("noResults");
  const noResultsMsgEl = document.getElementById("noResultsMsg");
  const searchInputEl = document.getElementById("searchInput");
  const searchBtnEl = document.getElementById("searchBtn");
  const clearBtnEl = document.getElementById("clearBtn");
  const viewAllBtnEl = document.getElementById("viewAllBtn");
  const prevPageBtnEl = document.getElementById("prevPageBtn");
  const nextPageBtnEl = document.getElementById("nextPageBtn");
  const pageNumbersEl = document.getElementById("pageNumbers");
  const paginationWrapEl = document.getElementById("paginationWrap");

  if (
    !(gridEl instanceof HTMLElement) ||
    !(sectionTitleEl instanceof HTMLElement) ||
    !(resultsHeaderEl instanceof HTMLElement) ||
    !(resultsTitleEl instanceof HTMLElement) ||
    !(noResultsEl instanceof HTMLElement) ||
    !(noResultsMsgEl instanceof HTMLElement) ||
    !(searchInputEl instanceof HTMLInputElement) ||
    !(searchBtnEl instanceof HTMLButtonElement) ||
    !(clearBtnEl instanceof HTMLButtonElement) ||
    !(viewAllBtnEl instanceof HTMLButtonElement) ||
    !(prevPageBtnEl instanceof HTMLButtonElement) ||
    !(nextPageBtnEl instanceof HTMLButtonElement) ||
    !(pageNumbersEl instanceof HTMLElement) ||
    !(paginationWrapEl instanceof HTMLElement)
  ) {
    return;
  }

  const grid = gridEl;
  const sectionTitle = sectionTitleEl;
  const resultsHeader = resultsHeaderEl;
  const resultsTitle = resultsTitleEl;
  const noResults = noResultsEl;
  const noResultsMsg = noResultsMsgEl;
  const searchInput = searchInputEl;
  const searchBtn = searchBtnEl;
  const clearBtn = clearBtnEl;
  const viewAllBtn = viewAllBtnEl;
  const prevPageBtn = prevPageBtnEl;
  const nextPageBtn = nextPageBtnEl;
  const pageNumbers = pageNumbersEl;
  const paginationWrap = paginationWrapEl;
    const posts: Post[] = JSON.parse(grid.dataset.posts ?? "[]");
    console.log('First post coverImage:', posts[0]?.coverImage);
    const postsPerPage = Number(paginationWrap.dataset.postsPerPage ?? "6");

    let currentPosts: Post[] = [...posts];
    let currentPage = 1;

    function getTotalPages(list: Post[]): number {
      return Math.max(1, Math.ceil(list.length / postsPerPage));
    }
function cardHTML(post: Post): string {
  const imageHTML = post.coverImage
    ? `<img src="${post.coverImage}" alt="${post.title}" class="w-full h-40 object-cover" />`
    : `<div class="w-full h-40 bg-gray-300 flex items-center justify-center">
        <span class="text-gray-500 text-sm font-ui">Gaming Image Placeholder</span>
       </div>`;

  return `
    <article class="bg-white rounded-lg shadow-lg overflow-hidden hover:shadow-xl transition-shadow duration-300 h-full flex flex-col">
      ${imageHTML}
      <div class="p-4 flex flex-col flex-1">
        <a href="/${post.slug}" class="block group">
          <h3 class="text-lg font-semibold mb-2 text-gray-800 font-ui line-clamp-2 group-hover:text-brand transition-colors">
            ${post.title}
          </h3>
        </a>
        <p class="text-gray-600 mb-3 text-sm font-ui line-clamp-4">
          ${post.excerpt}
        </p>
        
          <a href="/${post.slug}"
          class="text-brand font-medium hover:underline inline-flex items-center font-ui mt-auto"
          aria-label="Read more about ${post.title}"
        >
          <span>Read more</span>
          <span class="sr-only"> about ${post.title}</span>
          <svg class="ml-1 h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        </a>
      </div>
    </article>
  `;
}

    function renderPagination(list: Post[]) {
      const totalPages = Math.max(1, getTotalPages(list));
      pageNumbers.innerHTML = "";

      const pages: (number | string)[] = [];

      if (totalPages <= 7) {
        for (let i = 1; i <= totalPages; i++) {
          pages.push(i);
        }
      } else {
        pages.push(1);

        if (currentPage > 3) pages.push("...");

        const start = Math.max(2, currentPage - 1);
        const end = Math.min(totalPages - 1, currentPage + 1);

        for (let i = start; i <= end; i++) {
          pages.push(i);
        }

        if (currentPage < totalPages - 2) pages.push("...");

        pages.push(totalPages);
      }

      pages.forEach((page) => {
        if (page === "...") {
          const ellipsis = document.createElement("span");
          ellipsis.className = "px-2 text-[#9CA3AF] text-xs sm:text-sm font-bold";
          ellipsis.textContent = "...";
          pageNumbers.appendChild(ellipsis);
          return;
        }

        const button = document.createElement("button");
        button.type = "button";
        button.textContent = String(page);

        button.className =
          currentPage === page
            ? "w-8 h-8 sm:w-9 sm:h-9 bg-[#00D02B] text-black font-ui text-[10px] sm:text-xs font-bold rounded shrink-0"
            : "w-8 h-8 sm:w-9 sm:h-9 bg-white border border-[#E5E7EB] text-[#6B7280] font-ui text-[10px] sm:text-xs font-bold rounded shrink-0 hover:border-[#00D02B]/40 hover:text-[#00D02B] transition-all duration-150";

        button.addEventListener("click", () => {
          currentPage = Number(page);
          renderPosts(list, currentPage);
          window.scrollTo({ top: grid.offsetTop - 120, behavior: "smooth" });
        });

        pageNumbers.appendChild(button);
      });

      prevPageBtn.disabled = currentPage === 1;
      nextPageBtn.disabled = currentPage === totalPages;
    }

    function renderPosts(list: Post[], page = 1) {
      const totalPages = getTotalPages(list);
      currentPage = Math.min(Math.max(page, 1), totalPages);

      if (list.length === 0) {
        grid.classList.add("hidden");
        noResults.classList.remove("hidden");
        paginationWrap.classList.add("hidden");
        return;
      }

      const start = (currentPage - 1) * postsPerPage;
      const visiblePosts = list.slice(start, start + postsPerPage);

      grid.classList.remove("hidden");
      noResults.classList.add("hidden");
      paginationWrap.classList.remove("hidden");
      grid.innerHTML = visiblePosts.map(cardHTML).join("");

      renderPagination(list);
    }

    function showAll() {
      currentPosts = [...posts];
      currentPage = 1;

      searchInput.value = "";
      sectionTitle.textContent = "Latest Articles";
      sectionTitle.classList.remove("hidden");
      resultsHeader.classList.add("hidden");
      noResults.classList.add("hidden");

      renderPosts(currentPosts, 1);
    }

    function handleSearch() {
      const term = searchInput.value.trim().toLowerCase();

      if (!term) {
        showAll();
        return;
      }

      const results = posts.filter(
        (post) =>
          post.title.toLowerCase().includes(term) ||
          post.excerpt.toLowerCase().includes(term)
      );

      currentPosts = results;
      currentPage = 1;

      sectionTitle.classList.add("hidden");
      resultsHeader.classList.remove("hidden");
      resultsTitle.textContent = `Search Results (${results.length})`;

      if (results.length === 0) {
        noResultsMsg.textContent = `No articles found for "${searchInput.value}"`;
      }

      renderPosts(currentPosts, 1);
    }

    if (!prevPageBtn.dataset.initialized) {
      prevPageBtn.dataset.initialized = "true";
      prevPageBtn.addEventListener("click", () => {
        if (currentPage > 1) {
          renderPosts(currentPosts, currentPage - 1);
          window.scrollTo({ top: grid.offsetTop - 120, behavior: "smooth" });
        }
      });
    }

    if (!nextPageBtn.dataset.initialized) {
      nextPageBtn.dataset.initialized = "true";
      nextPageBtn.addEventListener("click", () => {
        if (currentPage < getTotalPages(currentPosts)) {
          renderPosts(currentPosts, currentPage + 1);
          window.scrollTo({ top: grid.offsetTop - 120, behavior: "smooth" });
        }
      });
    }

    if (!searchBtn.dataset.initialized) {
      searchBtn.dataset.initialized = "true";
      searchBtn.addEventListener("click", handleSearch);
    }

    if (!searchInput.dataset.initialized) {
      searchInput.dataset.initialized = "true";
      searchInput.addEventListener("keydown", (e) => {
        if (e.key === "Enter") handleSearch();
      });
    }

    if (!clearBtn.dataset.initialized) {
      clearBtn.dataset.initialized = "true";
      clearBtn.addEventListener("click", showAll);
    }

    if (!viewAllBtn.dataset.initialized) {
      viewAllBtn.dataset.initialized = "true";
      viewAllBtn.addEventListener("click", showAll);
    }

    showAll();
  }

  document.addEventListener("astro:page-load", setupBlogPage);

 

</script>
</MainLayout>