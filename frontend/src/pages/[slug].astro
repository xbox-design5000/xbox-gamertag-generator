---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";
import RelatedTools from "../components/blog/RelatedTools.astro";
import { client, urlFor } from "../lib/sanity";
import { POST_QUERY } from "../lib/queries";
import { toHTML } from "@portabletext/to-html";
import AuthorBio from "../components/blog/AuthorBio.astro";
import RelatedPosts from "../components/blog/RelatedPosts.astro";
type TocItem = {
  id: string;
  title: string;
  level: number;
};

const { slug } = Astro.params;
const post = await client.fetch(POST_QUERY, { slug });

if (!post) {
  return Astro.redirect("/blog");
}

const bodyHtml = post.body ? toHTML(post.body) : '';
const coverImageUrl = post.coverImage
  ? urlFor(post.coverImage).width(1200).auto('format').url()
  : null;

const slugify = (text: string) =>
  text
    .toLowerCase()
    .replace(/&amp;|&/g, " and ")
    .replace(/<[^>]*>/g, "")
    .replace(/[^a-z0-9\s-]/g, "")
    .trim()
    .replace(/\s+/g, "-")
    .replace(/-+/g, "-");

const toc: TocItem[] = [];
const idCounts = new Map<string, number>();

const contentWithIds = bodyHtml.replace(
  /<h([23])>(.*?)<\/h\1>/gi,
  (_match: string, level: string, rawTitle: string) => {
    const plainTitle = rawTitle
      .replace(/<[^>]+>/g, "")
      .replace(/&amp;/g, "&")
      .trim();
    const baseId = slugify(plainTitle) || `section-${toc.length + 1}`;
    const count = (idCounts.get(baseId) ?? 0) + 1;
    idCounts.set(baseId, count);
    const finalId = count > 1 ? `${baseId}-${count}` : baseId;
    toc.push({ id: finalId, title: plainTitle, level: Number(level) });
    return `<h${level} id="${finalId}">${rawTitle}</h${level}>`;
  }
);

const articleUrl = `https://xboxgamertaggenerator.com/${slug}`;

const schema = {
  "@context": "https://schema.org",
  "@type": post.seo?.articleType || "BlogPosting",
  headline: post.title,
  url: articleUrl,
  description: post.seo?.metaDescription || post.excerpt,
  image: coverImageUrl,
  datePublished: post.publishedAt,
  dateModified: post.updatedAt || post.publishedAt,
  author: {
    "@type": "Person",
    name: post.author?.name || "Xbox Gamertag Generator",
    url: post.author?.slug ? `https://xboxgamertaggenerator.com/author/${post.author.slug}` : undefined,
  },
  publisher: {
    "@type": "Organization",
    name: "Xbox Gamertag Generator",
    url: "https://xboxgamertaggenerator.com",
  },
};
---

<MainLayout
  title={post.seo?.metaTitle || `${post.title} | Xbox Gamertag Guide`}
  description={post.seo?.metaDescription || post.excerpt}
  canonical={post.seo?.canonicalUrl || articleUrl}
  ogType="article"
  {schema}
>
  <Header />

  <div class="min-h-screen bg-gray-100 font-ui">

    <!-- Hero -->
    <section class="bg-white border-b border-white-border">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 sm:py-14">
        {post.categories && post.categories.length > 0 && (
          <div class="flex flex-wrap gap-2 justify-center mb-5">
            {post.categories.map((cat: any) => (
              
               <a href={`/blog/category/${cat.slug}`}
                class="badge-brand hover:opacity-80 transition-opacity"
              >
                {cat.name}
              </a>
            ))}
          </div>
        )}

        <h1
          class="text-2xl sm:text-3xl md:text-4xl font-bold text-center leading-tight mb-5 text-dark-heading"
          style="letter-spacing: -0.02em;"
        >
          {post.title}
        </h1>

        {post.excerpt && (
          <p class="text-center text-base sm:text-lg max-w-2xl mx-auto mb-8 leading-relaxed text-dark-body">
            {post.excerpt}
          </p>
        )}

        <div class="flex flex-wrap items-center justify-center gap-x-5 gap-y-2 text-sm text-dark-body">
          {post.author && (
            <div class="flex items-center gap-1.5">
              <svg class="h-4 w-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.966 10.966 0 0112 15c2.125 0 4.109.602 5.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
           <span>By <a href={`/author/${post.author.slug}`} class="font-semibold text-dark-heading hover:text-brand transition-colors">{post.author.name}</a></span>
            </div>
          )}
          {post.publishedAt && (
            <div class="flex items-center gap-1.5">
              <svg class="h-4 w-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
              </svg>
              <span>{new Date(post.publishedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </div>
          )}
          {post.readingTime && (
            <div class="flex items-center gap-1.5">
              <svg class="h-4 w-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0.11-18 0 9 9 0z" />
              </svg>
              <span>{post.readingTime} min read</span>
            </div>
          )}
          {post.updatedAt && (
            <div class="flex items-center gap-1.5">
              <svg class="h-4 w-4 flex-shrink-0" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
              </svg>
              <span>Updated {new Date(post.updatedAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
            </div>
          )}
        </div>
      </div>
    </section>

<!-- Cover Image -->
{coverImageUrl && (
  <section class="px-4 sm:px-6 lg:px-8 -mt-8 relative z-10 pt-5 pb-9 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="rounded-xl overflow-hidden shadow-lg">
        <img
          src={coverImageUrl}
          alt={post.coverImage?.alt || post.title}
          class="w-full h-auto"
          loading="eager"
        />
      </div>
    </div>
  </section>
)}
    <!-- Main Content -->
    <div class="bg-gray-100 min-h-screen pt-2 pb-0">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-0">
        <div class="flex flex-col lg:flex-row gap-8">

          <!-- Main Article -->
          <main class="flex-1 max-w-none order-1 lg:order-1">

            <!-- Mobile Ad Banner -->
            <div class="lg:hidden">
              <div class="bg-gray-100 rounded-lg p-4 text-center border-2 border-dashed border-gray-300 mb-6 mt-2">
                <p class="text-xs text-gray-500">Advertisement</p>
                <div class="h-32 bg-gray-200 rounded mt-2"></div>
              </div>
            </div>

            <div class="bg-white rounded-t-lg shadow-sm pb-12 min-h-screen my-0 py-4">
              <article class="p-6 sm:p-8">

                <!-- Table of Contents — inside article body -->
                {toc.length > 0 && (
                  <div class="mb-8" id="toc-wrapper">
                   <div class="bg-white rounded-lg shadow-sm border border-gray-200 transition-all duration-300">
  <div class="p-5" id="tocHeader">
                        <button
                          id="tocToggleBtn"
                          class="w-full flex items-center justify-between text-lg font-semibold text-gray-800 hover:text-brand transition-colors"
                        >
                          <div class="flex items-center gap-2">
                            <svg class="h-5 w-5 text-brand" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                            </svg>
                            Table of Contents
                          </div>
                          <svg id="tocArrow" class="h-5 w-5 text-gray-500 transition-transform duration-200" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                          </svg>
                        </button>
                      </div>
                      <div id="tocContent" class="overflow-hidden transition-all duration-300 ease-in-out">
                        <nav class="p-5">
                          <ul class="space-y-2 animate-fade-in">
                            {toc.filter(item => item.title.trim() !== '').map((item) => (
                              <li>
                                
                                  <a  href={`#${item.id}`}
                                  class:list={[
                                    "toc-link block text-sm transition-colors hover:text-brand",
                                    item.level === 3 ? "pl-4 text-gray-600" : "text-gray-700 font-medium"
                                  ]}
                                  data-section={item.id}
                                >
                                  {item.title}
                                </a>
                              </li>
                            ))}
                          </ul>
                        </nav>
                      </div>
                    </div>
                  </div>
                )}

                <!-- Article Body -->
                <div class="blog-content" set:html={contentWithIds} />

              </article>

              <!-- Author Bio — right after article body -->
              {post.author && (
                <div class="px-6 sm:px-8 pb-8 pt-6 border-t border-gray-200">
                  <AuthorBio author={post.author} />
                </div>
              )}

              <!-- CTA -->
              <div class="bg-brand rounded-lg p-6 text-center text-white m-6">
                <h3 class="text-xl font-bold mb-2">Ready to Create Your Gamertag?</h3>
                <p class="mb-4 text-sm opacity-95">
                  Use our free Xbox Gamertag Generator to find the perfect name for your gaming identity.
                </p>
                
                  <a  href="/"
                  class="inline-flex items-center gap-2 bg-white text-brand hover:bg-gray-100 font-semibold px-6 py-3 rounded-lg transition-colors text-sm"
                >
                  Try Generator Now
                  <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              </div>

            <!-- Related Posts -->
<section class="p-6 sm:p-8 border-t border-gray-200">
  <h2 class="text-2xl font-bold text-gray-800 mb-6">Related Posts</h2>
  <RelatedPosts posts={post.relatedPosts ?? []} />
</section>

              <!-- Related Tools — Lovable style -->
              <section class="p-6 sm:p-8 border-t border-gray-200">
                <h2 class="text-2xl font-bold text-gray-800 mb-6">Related Tools</h2>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                    <h3 class="text-xl font-bold mb-2 text-brand">Xbox Gamertag Generator</h3>
                    <p class="text-gray-600 mb-4">Generate unique Xbox gamertags instantly with our AI-powered tool.</p>
                    
                     <a   href="/"
                      class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors text-sm"
                    >
                      Go to Tool
                    </a>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                    <h3 class="text-xl font-bold mb-2 text-brand">Availability Checker</h3>
                    <p class="text-gray-600 mb-4">Check if your desired gamertag is available before someone else takes it.</p>
                    
                    <a  href="/xbox-gamertag-availability-checker"
                      class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors text-sm"
                    >
                      Go to Tool
                    </a>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                    <h3 class="text-xl font-bold mb-2 text-brand">Xbox Gamertag Search</h3>
                    <p class="text-gray-600 mb-4">Look up public Xbox profile details, Gamerscore, and game activity.</p>
                    
                     <a href="/xbox-gamertag-search"
                      class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors text-sm"
                    >
                      Go to Tool
                    </a>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                    <h3 class="text-xl font-bold mb-2 text-brand">Gamercard Generator</h3>
                    <p class="text-gray-600 mb-4">Create a custom Xbox-style profile card with your gamertag and avatar.</p>
                    
                    <a  href="/gamercard-generator"
                      class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors text-sm"
                    >
                      Go to Tool
                    </a>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                    <h3 class="text-xl font-bold mb-2 text-brand">Price Checker</h3>
                    <p class="text-gray-600 mb-4">Estimate whether a gamertag may be rare, short, or potentially valuable.</p>
                    
                    <a  href="/gamertag-price-checker"
                      class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors text-sm"
                    >
                      Go to Tool
                    </a>
                  </div>
                  <div class="bg-gray-50 rounded-lg p-6 border border-gray-200">
                    <h3 class="text-xl font-bold mb-2 text-brand">Gamertag Optimizer</h3>
                    <p class="text-gray-600 mb-4">Shorten, clean, and rewrite weak or messy Xbox gamertags into better options.</p>
                    
                    <a  href="/gamertag-optimizer"
                      class="inline-flex items-center justify-center bg-brand hover:bg-brand-light text-white font-semibold px-5 py-3 rounded-lg transition-colors text-sm"
                    >
                      Go to Tool
                    </a>
                  </div>
                </div>
              </section>

              <!-- Tags -->
              {post.tags && post.tags.length > 0 && (
                <div class="px-6 sm:px-8 pb-6 pt-4 border-t border-gray-200">
                  <p class="text-xs font-bold tracking-widest uppercase mb-3 text-gray-500">Tags</p>
                  <div class="flex flex-wrap gap-2">
                    {post.tags.map((tag: any) => (
                      <span class="text-xs px-3 py-1 rounded-full font-medium bg-gray-100 text-gray-700 border border-gray-200">
                        #{tag.name}
                      </span>
                    ))}
                  </div>
                </div>
              )}

              <!-- Share -->
              <div class="px-6 sm:px-8 pb-8 pt-4 border-t border-gray-200">
                <p class="text-xs font-bold tracking-widest uppercase mb-3 text-gray-500">Share this article</p>
                <div class="flex flex-col sm:flex-row gap-3">
                  
                   <a  href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(articleUrl)}&text=${encodeURIComponent(post.title)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 flex items-center justify-center gap-2 text-sm font-semibold px-5 py-3 rounded-lg bg-gray-50 text-gray-800 border border-gray-200 hover:border-brand transition-colors"
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.736-8.861L2.25 2.25H8.08l4.254 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                    Share on X
                  </a>
                  
                  <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(articleUrl)}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="flex-1 flex items-center justify-center gap-2 text-sm font-semibold px-5 py-3 rounded-lg bg-gray-50 text-gray-800 border border-gray-200 hover:border-brand transition-colors"
                  >
                    <svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                    </svg>
                    Share on Facebook
                  </a>
                </div>
              </div>

            </div>
          </main>

          <!-- Right Sidebar — Ad only, desktop only -->
          <aside class="hidden lg:block lg:w-64 flex-shrink-0 order-2 lg:order-2">
            <div class="sticky top-4 space-y-6 transition-all duration-200 my-0 py-[50px]">
              <div class="bg-gray-100 rounded-lg p-4 text-center border-2 border-dashed border-gray-300">
                <p class="text-xs text-gray-500">Advertisement</p>
                <div class="h-64 bg-gray-200 rounded mt-2"></div>
              </div>
            </div>
          </aside>

        </div>
      </div>
    </div>

  </div>

</MainLayout>

<script>
  // TOC toggle
  const tocToggleBtn = document.getElementById('tocToggleBtn');
  const tocContent = document.getElementById('tocContent');
  const tocArrow = document.getElementById('tocArrow');
  const tocHeader = document.getElementById('tocHeader');
  let tocOpen = false;

  if (tocToggleBtn && tocContent && tocArrow && tocHeader) {
    tocToggleBtn.addEventListener('click', () => {
      tocOpen = !tocOpen;
      if (tocOpen) {
        tocContent.style.maxHeight = tocContent.scrollHeight + 'px';
        tocContent.style.opacity = '1';
        tocArrow.style.transform = 'rotate(90deg)';
        tocHeader.classList.add('border-b', 'border-gray-100');
      } else {
        tocContent.style.maxHeight = '0';
        tocContent.style.opacity = '0';
        tocArrow.style.transform = 'rotate(0deg)';
        tocHeader.classList.remove('border-b', 'border-gray-100');
      }
    });

    // Initial state closed
    tocContent.style.maxHeight = '0';
    tocContent.style.opacity = '0';
    tocArrow.style.transform = 'rotate(0deg)';
    tocHeader.classList.remove('border-b', 'border-gray-100');
  }

  // Active TOC link on scroll
  const tocLinks = document.querySelectorAll('.toc-link');
  const sections = document.querySelectorAll('h2[id], h3[id]');

  function setActiveLink(id: string) {
    tocLinks.forEach(link => {
      const section = link.getAttribute('data-section');
      if (section === id) {
        link.classList.add('text-brand');
        link.classList.remove('text-gray-700', 'text-gray-600');
      } else {
        link.classList.remove('text-brand');
        if (link.classList.contains('pl-4')) {
          link.classList.add('text-gray-600');
        } else {
          link.classList.add('text-gray-700');
        }
      }
    });
  }

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          setActiveLink(entry.target.id);
        }
      });
    },
    { rootMargin: '-80px 0px -60% 0px', threshold: 0 }
  );

  sections.forEach(section => observer.observe(section));
</script>