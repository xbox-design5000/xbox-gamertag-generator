---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

const pageUrl = "https://xboxgamertaggenerator.com/xbox-gamertag-search";

const faqItems = [
  {
    question: "How do I search for someone's Xbox gamertag?",
    answer: "Enter their exact gamertag in the search field and click Look Up. The tool will search for the public Xbox Live profile connected to that name."
  },
  {
    question: "Can you look someone up by their gamertag?",
    answer: "Yes. If the player has a public Xbox profile you can look them up using their gamertag. Private profiles will not show data."
  },
  {
    question: "Does this tool show real-time Xbox data?",
    answer: "This tool pulls publicly available data from Xbox Live. Results are not live and may not reflect the most recent activity. For the latest stats, check the Xbox app directly."
  },
  {
    question: "What if someone's profile is set to private?",
    answer: "If a profile is set to private, no data will appear in the search results. Only the account holder can view private profile information."
  },
  {
    question: "Can I see someone's game history by gamertag?",
    answer: "Yes, if their profile is set to public. Recent game history and achievements may be visible depending on the player's privacy settings."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Xbox Gamertag Search",
  "url": pageUrl,
  "description": "Search any Xbox gamertag and look up public profile details, Gamerscore, achievements, and game history. Free Xbox profile lookup tool.",
  "applicationCategory": "GameApplication",
  "operatingSystem": "Web",
  "inLanguage": "en-US",
  "isAccessibleForFree": true,
  "creator": {
    "@type": "Organization",
    "name": "Xbox Gamertag Generator",
    "url": "https://xboxgamertaggenerator.com"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "potentialAction": {
    "@type": "UseAction",
    "target": pageUrl
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<MainLayout
  title="Xbox Gamertag Search — Look Up Xbox Profiles, Gamerscore & Stats"
  description="Search any Xbox gamertag and look up public profile details, Gamerscore, achievements, and game history. Free Xbox profile lookup tool — no sign-up needed."
  canonical={pageUrl}
  {schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />

  <div class="min-h-screen bg-[#F3F4F6] text-[#111827] font-ui">

    <!-- ── Hero ── -->
    <section class="section-dark-alt py-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12">
        <div class="bg-card border border-default rounded-xl py-14 md:py-16 px-6 md:px-10 text-center shadow-card relative overflow-hidden">
          <div class="bg-hero-glow absolute inset-0 pointer-events-none"></div>

          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-dim border border-green rounded-sm mb-6">
