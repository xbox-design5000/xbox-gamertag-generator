            </div>

            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mb-4 leading-tight">
              Xbox Gamertag <span class="text-brand">Search</span>
            </h1>

            <p class="text-foreground-muted text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
              The Xbox Gamertag Search tool lets you look up public Xbox profiles by gamertag. Enter any gamertag below to see available profile details including Gamerscore, recent games, and achievements.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Tool ── -->
    <section class="section-white-subtle py-10">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 space-y-5">

        <!-- Search Card -->
