  function loadImg(file:File,cb:(img:HTMLImageElement)=>void){
    const r=new FileReader();
    r.onload=e=>{
      const i=new Image();
      i.onload=()=>cb(i);
      i.src=e.target?.result as string;
    };
    r.readAsDataURL(file);
  }

  function hex2rgb(hex:string){
    const v=hex.replace("#","");
    const n=v.length===3 ? v.split("").map(c=>c+c).join("") : v;
    const b=parseInt(n,16);
    return {r:(b>>16)&255,g:(b>>8)&255,b:b&255};
  }

  function rgba(hex:string,a:number){
    const {r,g,b}=hex2rgb(hex);
    return `rgba(${r},${g},${b},${a})`;
  }

  function clamp(n:number,min:number,max:number){
    return Math.min(max,Math.max(min,n));
  }

  function fontPx(font:string){
    const m=font.match(/(\d+(\.\d+)?)px/);
    return m ? Number(m[1]) : 16;
  }

  function measure(text:string,font:string){
    ctx.save();
    ctx.font=font;
    const w=ctx.measureText(text).width;
    ctx.restore();
    return w;
  }

  function fitText(text:string,maxW:number,font:string){
    if(!text) return "";
    if(maxW<=0) return "";
    ctx.save();
    ctx.font=font;
    if(ctx.measureText(text).width<=maxW){
      ctx.restore();
      return text;
    }
    let out=text;
    while(out.length>1 && ctx.measureText(`${out}…`).width>maxW){
      out=out.slice(0,-1);
    }
    ctx.restore();
    return `${out}…`;
  }

  function fitRowsToHeight(
    availableH:number,
    desiredFontPx:number,
    desiredGap:number,
    rowCount:number,
    minFontPx:number,
    minGap:number
  ){
    let fontPxVal = desiredFontPx;
    let gap = desiredGap;

    while(
      rowCount > 0 &&
      (rowCount * fontPxVal + Math.max(0, rowCount - 1) * gap > availableH) &&
      fontPxVal > minFontPx
    ){
      fontPxVal -= 1;
      gap = Math.max(minGap, gap - 0.5);
    }

    return { fontPx: fontPxVal, gap };
  }

  function safeExportScale(requested:number, w:number, h:number){
    let scale = Math.max(1, requested);
    while(
      scale > 1 &&
      (
        w * scale > 12000 ||
        h * scale > 12000 ||
        (w * h * scale * scale) > 95000000
      )
    ){
      scale -= 1;
    }
    return scale;
  }

  function rr(x:number,y:number,w:number,h:number,r:number){
    ctx.beginPath();
    ctx.moveTo(x+r,y);
    ctx.lineTo(x+w-r,y);
    ctx.quadraticCurveTo(x+w,y,x+w,y+r);
    ctx.lineTo(x+w,y+h-r);
    ctx.quadraticCurveTo(x+w,y+h,x+w-r,y+h);
    ctx.lineTo(x+r,y+h);
    ctx.quadraticCurveTo(x,y+h,x,y+h-r);
    ctx.lineTo(x,y+r);
    ctx.quadraticCurveTo(x,y,x+r,y);
    ctx.closePath();
  }

  function applyCtxQuality(){
    ctx = canvas.getContext("2d")!;
    ctx.imageSmoothingEnabled = true;
    ctx.imageSmoothingQuality = "high";
  }

  function resizeCanvas(){
    canvas.width = selExport.width;
    canvas.height = selExport.height;
    applyCtxQuality();
    elPreviewLabel.textContent = `${selExport.label} • ${selExport.width}×${selExport.height}`;
  }

  function drawIcon(name:IconName,x:number,y:number,size:number,color:string,lineWidth=Math.max(1.6,size*0.1),filled=false){
    const s=size;
    const cx=x+s/2;
    const cy=y+s/2;

    ctx.save();
    ctx.strokeStyle=color;
    ctx.fillStyle=color;
    ctx.lineWidth=lineWidth;
    ctx.lineCap="round";
    ctx.lineJoin="round";

    if(name==="circle"){
      ctx.beginPath();
      ctx.arc(cx,cy,s*0.22,0,Math.PI*2);
      filled ? ctx.fill() : ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="zap"){
      ctx.beginPath();
      ctx.moveTo(x+s*0.58,y+s*0.08);
      ctx.lineTo(x+s*0.28,y+s*0.56);
      ctx.lineTo(x+s*0.50,y+s*0.56);
      ctx.lineTo(x+s*0.40,y+s*0.92);
      ctx.lineTo(x+s*0.72,y+s*0.42);
      ctx.lineTo(x+s*0.50,y+s*0.42);
      ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="diamond"){
      ctx.beginPath();
      ctx.moveTo(cx,y+s*0.1);
      ctx.lineTo(x+s*0.82,cy);
      ctx.lineTo(cx,y+s*0.9);
      ctx.lineTo(x+s*0.18,cy);
      ctx.closePath();
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(x+s*0.18,cy);
      ctx.lineTo(x+s*0.82,cy);
      ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="sparkles"){
      ctx.beginPath();
      ctx.moveTo(cx,y+s*0.08);
      ctx.lineTo(cx,y+s*0.34);
      ctx.moveTo(cx,y+s*0.66);
      ctx.lineTo(cx,y+s*0.92);
      ctx.moveTo(x+s*0.08,cy);
      ctx.lineTo(x+s*0.34,cy);
      ctx.moveTo(x+s*0.66,cy);
      ctx.lineTo(x+s*0.92,cy);
      ctx.moveTo(x+s*0.24,y+s*0.24);
      ctx.lineTo(x+s*0.38,y+s*0.38);
      ctx.moveTo(x+s*0.62,y+s*0.62);
      ctx.lineTo(x+s*0.76,y+s*0.76);
      ctx.moveTo(x+s*0.62,y+s*0.38);
      ctx.lineTo(x+s*0.76,y+s*0.24);
      ctx.moveTo(x+s*0.24,y+s*0.76);
      ctx.lineTo(x+s*0.38,y+s*0.62);
      ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="flame"){
      ctx.beginPath();
      ctx.moveTo(cx,y+s*0.1);
      ctx.bezierCurveTo(x+s*0.82,y+s*0.26,x+s*0.76,y+s*0.56,cx,y+s*0.9);
      ctx.bezierCurveTo(x+s*0.22,y+s*0.72,x+s*0.18,y+s*0.34,cx,y+s*0.1);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(cx,y+s*0.34);
      ctx.bezierCurveTo(x+s*0.62,y+s*0.44,x+s*0.60,y+s*0.62,cx,y+s*0.8);
      ctx.bezierCurveTo(x+s*0.38,y+s*0.68,x+s*0.34,y+s*0.5,cx,y+s*0.34);
      ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="calendar"){
      rr(x+s*0.14,y+s*0.2,s*0.72,s*0.66,s*0.08);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(x+s*0.14,y+s*0.42);
      ctx.lineTo(x+s*0.86,y+s*0.42);
      ctx.moveTo(x+s*0.32,y+s*0.08);
      ctx.lineTo(x+s*0.32,y+s*0.28);
      ctx.moveTo(x+s*0.68,y+s*0.08);
      ctx.lineTo(x+s*0.68,y+s*0.28);
      ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="messageSquare"){
      rr(x+s*0.12,y+s*0.14,s*0.76,s*0.58,s*0.12);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(x+s*0.32,y+s*0.72);
      ctx.lineTo(x+s*0.26,y+s*0.9);
      ctx.lineTo(x+s*0.48,y+s*0.72);
      ctx.stroke();
      ctx.restore();
      return;
    }

    if(name==="gamepad2"){
      rr(x+s*0.1,y+s*0.34,s*0.8,s*0.34,s*0.16);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(x+s*0.27,y+s*0.44);
      ctx.lineTo(x+s*0.27,y+s*0.58);
      ctx.moveTo(x+s*0.20,y+s*0.51);
      ctx.lineTo(x+s*0.34,y+s*0.51);
      ctx.stroke();

      ctx.beginPath();
      ctx.arc(x+s*0.64,y+s*0.48,s*0.03,0,Math.PI*2);
      ctx.fill();
      ctx.beginPath();
      ctx.arc(x+s*0.73,y+s*0.56,s*0.03,0,Math.PI*2);
      ctx.fill();
      ctx.restore();
      return;
    }

    if(name==="trophy"){
      rr(x+s*0.24,y+s*0.16,s*0.52,s*0.38,s*0.08);
      ctx.stroke();

      ctx.beginPath();
      ctx.moveTo(x+s*0.76,y+s*0.22);
      ctx.quadraticCurveTo(x+s*0.92,y+s*0.22,x+s*0.88,y+s*0.42);
      ctx.quadraticCurveTo(x+s*0.84,y+s*0.58,x+s*0.70,y+s*0.56);

      ctx.moveTo(x+s*0.24,y+s*0.22);
      ctx.quadraticCurveTo(x+s*0.08,y+s*0.22,x+s*0.12,y+s*0.42);
      ctx.quadraticCurveTo(x+s*0.16,y+s*0.58,x+s*0.30,y+s*0.56);

      ctx.moveTo(cx,y+s*0.54);
      ctx.lineTo(cx,y+s*0.76);
      ctx.moveTo(x+s*0.32,y+s*0.86);
      ctx.lineTo(x+s*0.68,y+s*0.86);
      ctx.stroke();
      ctx.restore();
      return;
    }

    ctx.restore();
  }

  function drawStatusPillMetrics(label:string,fontSize:number){
    const font=`700 ${fontSize}px "Barlow Condensed",sans-serif`;
    const dotSize=Math.max(8,fontSize*0.72);
    const gap=Math.max(6,fontSize*0.35);
    const height=Math.max(fontSize+12,dotSize+10);
    const width=measure(label,font)+dotSize+gap+20;
    return {width,height,dotSize,gap,font};
  }

  function drawStatusPill(x:number,y:number,label:string,color:string,fontSize:number){
    const m=drawStatusPillMetrics(label,fontSize);
    rr(x,y,m.width,m.height,999);
    ctx.fillStyle=rgba(color,0.12);
    ctx.fill();
    ctx.strokeStyle=rgba(color,0.4);
    ctx.lineWidth=1.2;
    ctx.stroke();

    drawIcon("circle",x+10,y+(m.height-m.dotSize)/2,m.dotSize,color,1.8,true);
    txt(label,x+10+m.dotSize+m.gap,y+(m.height-fontSize)/2-1,color,m.font,"left");

    return m.width;
  }

  function drawBadgeChip(x:number,y:number,icon:IconName,label:string,accent:string,fontSize:number){
    const font=`600 ${fontSize}px "Barlow Condensed",sans-serif`;
    const iconSize=clamp(fontSize*0.95,12,16);
    const gap=6;
    const textW=measure(label,font);
    const bw=textW+iconSize+gap+22;
    const bh=Math.max(fontSize+14,iconSize+10);

    rr(x,y,bw,bh,999);
    ctx.fillStyle=rgba(accent,0.06);
    ctx.fill();
    ctx.strokeStyle=rgba(accent,0.22);
    ctx.lineWidth=1;
    ctx.stroke();

    drawIcon(icon,x+10,y+(bh-iconSize)/2,iconSize,"#ffffff",1.7);
    txt(label,x+10+iconSize+gap,y+(bh-fontSize)/2-1,"rgba(255,255,255,0.88)",font,"left");

    return bw;
  }

  function drawBadges(x:number,y:number,accent:string,maxW:number){
    if(!iToggleBg.checked || selBadges.length===0) return;

    const badges=badgePresets.filter(b=>selBadges.includes(b.id)).slice(0,4);
    let cx=x;
    const fSize=clamp(maxW/34,10,13);

    badges.forEach(badge=>{
      const font=`600 ${fSize}px "Barlow Condensed",sans-serif`;
      const iconSize=clamp(fSize*0.95,12,16);
      const bw=measure(badge.label,font)+iconSize+6+22;
      if(cx+bw>x+maxW) return;
      const usedW=drawBadgeChip(cx,y,badge.icon,badge.label,accent,fSize);
      cx+=usedW+6;
    });
  }

  function txt(text:string,x:number,y:number,color:string,font:string,align:"left"|"center"|"right"="left",maxW?:number){
    ctx.save();
    ctx.font=font;
    ctx.fillStyle=color;
    ctx.textAlign=align;
    ctx.textBaseline="top";
    if(maxW) ctx.fillText(text,x,y,maxW);
    else ctx.fillText(text,x,y);
    ctx.restore();
  }

  function drawSep(x:number,y:number,w:number,accent:string){
    const sg=ctx.createLinearGradient(x,y,x+w,y);
    sg.addColorStop(0,"transparent");
    sg.addColorStop(0.3,rgba(accent,0.35));
    sg.addColorStop(0.7,rgba(accent,0.35));
    sg.addColorStop(1,"transparent");
    ctx.save();
    ctx.strokeStyle=sg;
    ctx.lineWidth=1;
    ctx.beginPath();
    ctx.moveTo(x,y);
    ctx.lineTo(x+w,y);
    ctx.stroke();
    ctx.restore();
  }

  function drawInfoRow(
    x:number,
    y:number,
    icon:IconName,
    text:string,
    color:string,
    font:string,
    align:"left"|"center"="left",
    maxW=240,
    iconColor=color
  ){
    if(!text) return;
    const fpx=fontPx(font);
    const iconSize=clamp(fpx*0.9,13,22);
    const gap=clamp(fpx*0.36,6,10);
    const safe=fitText(text,Math.max(0,maxW-iconSize-gap),font);
    const textW=measure(safe,font);
    const totalW=iconSize+gap+textW;
    const startX=align==="center" ? x-totalW/2 : x;

    drawIcon(icon,startX,y+Math.max(0,(fpx-iconSize)/2),iconSize,iconColor,Math.max(1.6,iconSize*0.1));
    txt(safe,startX+iconSize+gap,y,color,font,"left");
  }

  function getMetaRows(score:string,since:string,game:string,pres:string,accent:string){
    const rows: {icon:IconName;text:string;color:string;iconColor:string}[] = [
      { icon:"trophy", text:`${score} Gamerscore`, color:"#ffffff", iconColor:accent },
    ];

    if(game){
      rows.push({ icon:"gamepad2", text:game, color:"rgba(255,255,255,0.86)", iconColor:accent });
    }

    if(since){
      rows.push({ icon:"calendar", text:`Member since ${since}`, color:"rgba(255,255,255,0.72)", iconColor:accent });
    }

    if(pres){
      rows.push({ icon:"messageSquare", text:pres, color:"rgba(255,255,255,0.58)", iconColor:accent });
    }

    return rows;
  }

  function drawBg(W:number,H:number,accent:string){
    const rad=Math.max(16,W*0.02);
    ctx.save();
    rr(0,0,W,H,rad);
    ctx.clip();

    if(custBg){
      const sc=Math.max(W/custBg.width,H/custBg.height);
      const bw=custBg.width*sc;
      const bh=custBg.height*sc;
      ctx.drawImage(custBg,(W-bw)/2,(H-bh)/2,bw,bh);
      ctx.fillStyle=`rgba(0,0,0,${parseInt(elBgOpacity.value)/100})`;
      ctx.fillRect(0,0,W,H);
    } else {
      const preset=iBgPreset.value;

      if(preset==="green-gradient"){
        const g=ctx.createLinearGradient(0,0,W,H);
        g.addColorStop(0,selTheme.bg);
        g.addColorStop(1,rgba(accent,0.6));
        ctx.fillStyle=g;
        ctx.fillRect(0,0,W,H);
      } else if(preset==="blue-nebula"){
        ctx.fillStyle="#020b18";
        ctx.fillRect(0,0,W,H);
        const g=ctx.createRadialGradient(W*.65,H*.25,0,W*.65,H*.25,Math.max(W,H)*.6);
        g.addColorStop(0,rgba("#3b82f6",0.5));
        g.addColorStop(0.5,rgba("#1d4ed8",0.2));
        g.addColorStop(1,"transparent");
        ctx.fillStyle=g;
        ctx.fillRect(0,0,W,H);

        const g2=ctx.createRadialGradient(W*.15,H*.7,0,W*.15,H*.7,Math.max(W,H)*.4);
        g2.addColorStop(0,rgba("#7c3aed",0.3));
        g2.addColorStop(1,"transparent");
        ctx.fillStyle=g2;
        ctx.fillRect(0,0,W,H);
      } else if(preset==="gold-wave"){
        ctx.fillStyle="#060400";
        ctx.fillRect(0,0,W,H);
        const g=ctx.createLinearGradient(0,0,W,H);
        g.addColorStop(0,rgba("#78500a",0.4));
        g.addColorStop(0.5,rgba("#f59e0b",0.18));
        g.addColorStop(1,rgba("#78500a",0.4));
        ctx.fillStyle=g;
        ctx.fillRect(0,0,W,H);
      } else if(preset==="purple-haze"){
        ctx.fillStyle="#06020f";
        ctx.fillRect(0,0,W,H);
        const g=ctx.createRadialGradient(W*.5,H*.5,0,W*.5,H*.5,Math.max(W,H)*.7);
        g.addColorStop(0,rgba("#7c3aed",0.4));
        g.addColorStop(0.6,rgba("#4c1d95",0.2));
        g.addColorStop(1,"transparent");
        ctx.fillStyle=g;
        ctx.fillRect(0,0,W,H);
      } else if(preset==="midnight"){
        const g=ctx.createLinearGradient(0,0,0,H);
        g.addColorStop(0,"#080e1e");
        g.addColorStop(1,"#020509");
        ctx.fillStyle=g;
        ctx.fillRect(0,0,W,H);
      } else if(preset==="carbon"){
        ctx.fillStyle=selTheme.bg;
        ctx.fillRect(0,0,W,H);

        const gridSz=Math.max(6,W*0.01);
        ctx.strokeStyle=rgba(accent,0.1);
        ctx.lineWidth=0.6;
        for(let x=0;x<W;x+=gridSz){
          ctx.beginPath();
          ctx.moveTo(x,0);
          ctx.lineTo(x,H);
          ctx.stroke();
        }
        for(let y=0;y<H;y+=gridSz){
          ctx.beginPath();
          ctx.moveTo(0,y);
          ctx.lineTo(W,y);
          ctx.stroke();
        }
      } else {
        ctx.fillStyle=selTheme.bg;
        ctx.fillRect(0,0,W,H);
      }
    }

    const accentGlowA=ctx.createRadialGradient(W*0.82,H*0.18,0,W*0.82,H*0.18,Math.max(W,H)*0.7);
    accentGlowA.addColorStop(0,rgba(accent,0.16));
    accentGlowA.addColorStop(1,"transparent");
    ctx.fillStyle=accentGlowA;
    ctx.fillRect(0,0,W,H);

    const accentGlowB=ctx.createRadialGradient(W*0.06,H*0.9,0,W*0.06,H*0.9,Math.max(W,H)*0.6);
    accentGlowB.addColorStop(0,rgba(accent,0.14));
    accentGlowB.addColorStop(1,"transparent");
    ctx.fillStyle=accentGlowB;
    ctx.fillRect(0,0,W,H);

    ctx.save();
    ctx.globalAlpha = custBg ? 0.08 : 0.07;
    ctx.strokeStyle = accent;
    ctx.lineWidth = Math.max(1,W*0.002);
    const spacing = Math.max(20,W*0.04);
    for(let i=-H;i<W+H;i+=spacing){
      ctx.beginPath();
      ctx.moveTo(i,0);
      ctx.lineTo(i+H,H);
      ctx.stroke();
    }
    ctx.restore();

    if(selStyle.glass){
      const gl=ctx.createLinearGradient(0,0,W,H);
      gl.addColorStop(0,"rgba(255,255,255,0.07)");
      gl.addColorStop(1,"rgba(255,255,255,0.01)");
      ctx.fillStyle=gl;
      ctx.fillRect(0,0,W,H);
    }

    if(selStyle.scanline){
      const lineH=Math.max(2,H*0.008);
      ctx.save();
      ctx.globalAlpha=0.06;
      ctx.fillStyle="#000";
      for(let y=0;y<H;y+=lineH*2){
        ctx.fillRect(0,y,W,lineH);
      }
      ctx.restore();
    }

    ctx.restore();
  }

  function drawFrame(W:number,H:number,accent:string){
    const rad=Math.max(16,W*0.02);

    if(selStyle.strip){
      const sw=Math.max(4,Math.round(W*0.006));
      const sg=ctx.createLinearGradient(0,0,0,H);
      sg.addColorStop(0,rgba(accent,0.3));
      sg.addColorStop(0.5,accent);
      sg.addColorStop(1,rgba(accent,0.3));
      ctx.fillStyle=sg;
      ctx.fillRect(0,0,sw,H);
    }

    if(selStyle.glow){
      ctx.save();
      ctx.shadowColor=rgba(accent,0.7);
      ctx.shadowBlur=Math.max(18,W*0.025);
      ctx.strokeStyle=rgba(accent,0.25);
      ctx.lineWidth=Math.max(3,W*0.004);
      rr(6,6,W-12,H-12,rad-4);
      ctx.stroke();
      ctx.restore();
    }

    ctx.save();
    rr(1,1,W-2,H-2,rad);
    ctx.strokeStyle=rgba(accent,0.35);
    ctx.lineWidth=1.5;
    ctx.stroke();

    rr(3,3,W-6,H-6,rad-2);
    ctx.strokeStyle=rgba(accent,0.08);
    ctx.lineWidth=1;
    ctx.stroke();
    ctx.restore();
  }

  function drawAvatar(x:number,y:number,sz:number,accent:string,statusColor:string){
    const shape=iShape.value;
    const cx=x+sz/2;
    const cy=y+sz/2;
    const r=sz/2;
    const cornerR=Math.max(14,sz*0.22);

    ctx.save();

    ctx.save();
    ctx.shadowColor=rgba(accent,0.5);
    ctx.shadowBlur=Math.max(10,sz*0.12);
    if(shape==="rounded"){
      rr(x,y,sz,sz,cornerR);
    } else {
      ctx.beginPath();
      ctx.arc(cx,cy,r,0,Math.PI*2);
    }
    ctx.strokeStyle=rgba(accent,0.6);
    ctx.lineWidth=Math.max(2,sz*0.028);
    ctx.stroke();
    ctx.restore();

    ctx.save();
    if(shape==="rounded"){
      rr(x+3,y+3,sz-6,sz-6,cornerR-2);
    } else {
      ctx.beginPath();
      ctx.arc(cx,cy,r-2,0,Math.PI*2);
    }
    ctx.clip();

    if(custAvatar){
      ctx.drawImage(custAvatar,x+3,y+3,sz-6,sz-6);
    } else {
      const bg=ctx.createRadialGradient(cx,cy,0,cx,cy,r);
      bg.addColorStop(0,rgba(accent,0.22));
      bg.addColorStop(1,rgba(accent,0.06));
      ctx.fillStyle=bg;
      ctx.fillRect(x,y,sz,sz);
      ctx.font=`${Math.floor(sz*0.46)}px serif`;
      ctx.textAlign="center";
      ctx.textBaseline="middle";
      ctx.fillStyle="#fff";
      ctx.fillText(selAvatar.emoji,cx,cy+Math.floor(sz*0.03));
    }
    ctx.restore();

    const dotR=Math.max(7,sz*0.11);
    const dotX=x+sz-dotR*0.8;
    const dotY=y+sz-dotR*0.8;
    ctx.save();
    ctx.shadowColor=rgba(statusColor,0.6);
    ctx.shadowBlur=8;
    ctx.beginPath();
    ctx.arc(dotX,dotY,dotR+2.5,0,Math.PI*2);
    ctx.fillStyle=selTheme.bg;
    ctx.fill();
    ctx.beginPath();
    ctx.arc(dotX,dotY,dotR,0,Math.PI*2);
    ctx.fillStyle=statusColor;
    ctx.fill();
    ctx.restore();
  }

  function drawWide(W:number,H:number,accent:string,sc:string,sl:string,tag:string,score:string,since:string,game:string,pres:string){
    const pad=clamp(W*0.038,18,36);
    const aSz=clamp(H*0.52,84,H-34);
    const aX=pad;
    const aY=(H-aSz)/2;
    drawAvatar(aX,aY,aSz,accent,sc);

    const contentX=aX+aSz+clamp(W*0.028,16,32);
    const contentW=W-contentX-pad;

    const nameFont=`800 ${clamp(H*0.21,24,42)}px "Barlow Condensed",sans-serif`;
    const pillSize=clamp(H*0.075,10,15);

    const nameY=clamp(H*0.08,14,22);
    txt(fitText(tag,contentW,nameFont),contentX,nameY,"#ffffff",nameFont,"left");
    drawSep(contentX,nameY+fontPx(nameFont)+5,contentW,accent);

    const pillY=nameY+fontPx(nameFont)+12;
    const pillH=drawStatusPillMetrics(sl,pillSize).height;
    drawStatusPill(contentX,pillY,sl,sc,pillSize);

    const rows=getMetaRows(score,since,game,pres,accent);
    const badgesReserve = iToggleBg.checked && selBadges.length ? 28 : 8;
    const rowsStartY = pillY + pillH + 8;
    const rowsAvailableH = H - rowsStartY - badgesReserve - 8;

    const fitted = fitRowsToHeight(
      rowsAvailableH,
      clamp(H*0.068,11,15),
      clamp(H*0.018,3,7),
      rows.length,
      9,
      2
    );

    const rowFont=`600 ${fitted.fontPx}px "Rajdhani",sans-serif`;
    let rowY=rowsStartY;

    rows.forEach(row=>{
      drawInfoRow(contentX,rowY,row.icon,row.text,row.color,rowFont,"left",contentW,row.iconColor);
      rowY+=fitted.fontPx+fitted.gap;
    });

    drawBadges(contentX,H-24,accent,contentW);
  }

  function drawSquare(W:number,H:number,accent:string,sc:string,sl:string,tag:string,score:string,since:string,game:string,pres:string){
    const cx=W/2;
    const aSz=clamp(W*0.27,210,330);
    const aY=H*0.055;
    drawAvatar(cx-aSz/2,aY,aSz,accent,sc);

    const nameFont=`800 ${clamp(W*0.074,52,88)}px "Barlow Condensed",sans-serif`;
    const pillSize=clamp(W*0.03,20,34);
    const rows=getMetaRows(score,since,game,pres,accent);

    const nameY=aY+aSz+H*0.028;
    txt(fitText(tag,W*0.84,nameFont),cx,nameY,"#ffffff",nameFont,"center");
    drawSep(W*0.1,nameY+fontPx(nameFont)+12,W*0.8,accent);

    const pillM=drawStatusPillMetrics(sl,pillSize);
    const pillY=nameY+fontPx(nameFont)+26;
    drawStatusPill(cx-pillM.width/2,pillY,sl,sc,pillSize);

    const badgesReserve = iToggleBg.checked && selBadges.length ? 96 : 44;
    const rowsStartY = pillY + pillM.height + 34;
    const rowsAvailableH = H - rowsStartY - badgesReserve;

    const fitted = fitRowsToHeight(
      rowsAvailableH,
      clamp(W*0.036,24,38),
      clamp(H*0.024,12,22),
      rows.length,
      18,
      8
    );

    const rowFont=`600 ${fitted.fontPx}px "Rajdhani",sans-serif`;
    let rowY=rowsStartY;

    rows.forEach(row=>{
      drawInfoRow(cx,rowY,row.icon,row.text,row.color,rowFont,"center",W*0.8,row.iconColor);
      rowY+=fitted.fontPx+fitted.gap;
    });

    drawBadges(W*0.12,H-92,accent,W*0.76);
  }

  function drawStory(W:number,H:number,accent:string,sc:string,sl:string,tag:string,score:string,since:string,game:string,pres:string){
    const cx=W/2;
    const aSz=clamp(W*0.33,250,390);
    const aY=H*0.055;
    drawAvatar(cx-aSz/2,aY,aSz,accent,sc);

    const nameFont=`800 ${clamp(W*0.082,56,94)}px "Barlow Condensed",sans-serif`;
    const pillSize=clamp(W*0.033,22,34);
    const rows=getMetaRows(score,since,game,pres,accent);

    const nameY=aY+aSz+H*0.024;
    txt(fitText(tag,W*0.86,nameFont),cx,nameY,"#ffffff",nameFont,"center");
    drawSep(W*0.08,nameY+fontPx(nameFont)+12,W*0.84,accent);

    const pillM=drawStatusPillMetrics(sl,pillSize);
    const pillY=nameY+fontPx(nameFont)+26;
    drawStatusPill(cx-pillM.width/2,pillY,sl,sc,pillSize);

    const panelX=W*0.075;
    const panelW=W*0.85;
    const innerPadX=clamp(W*0.055,28,42);
    const innerPadY=clamp(H*0.022,28,44);

    const desiredFontPx = clamp(W*0.035,24,36);
    const desiredGap = clamp(H*0.022,16,26);
    const fitted = fitRowsToHeight(
      H*0.34,
      desiredFontPx,
      desiredGap,
      rows.length,
      18,
      10
    );

    const rowFont=`600 ${fitted.fontPx}px "Rajdhani",sans-serif`;
    const rowFontPx=fontPx(rowFont);
    const panelH=innerPadY*2 + rows.length*rowFontPx + Math.max(0,rows.length-1)*fitted.gap + 10;
    const panelY=pillY+pillM.height+clamp(H*0.03,30,52);

    ctx.save();
    rr(panelX,panelY,panelW,panelH,26);
    ctx.fillStyle=rgba(accent,0.06);
    ctx.fill();
    ctx.strokeStyle=rgba(accent,0.24);
    ctx.lineWidth=1.5;
    ctx.stroke();
    ctx.restore();

    let rowY=panelY+innerPadY;
    rows.forEach((row,index)=>{
      drawInfoRow(panelX+innerPadX,rowY,row.icon,row.text,row.color,rowFont,"left",panelW-innerPadX*2,row.iconColor);
      if(index<rows.length-1){
        drawSep(panelX+22,rowY+rowFontPx+fitted.gap/2,panelW-44,accent);
      }
      rowY+=rowFontPx+fitted.gap;
    });

    drawBadges(panelX+18,Math.min(H-108,panelY+panelH+34),accent,panelW-36);
  }

  function drawBanner(W:number,H:number,accent:string,sc:string,sl:string,tag:string,score:string,since:string,game:string,pres:string){
    const pad=clamp(W*0.04,28,60);
    const aSz=clamp(H*0.58,160,H-44);
    const aX=pad;
    const aY=(H-aSz)/2;
    drawAvatar(aX,aY,aSz,accent,sc);

    const contentX=aX+aSz+clamp(W*0.025,24,42);
    const contentW=W-contentX-pad;

    const nameFont=`800 ${clamp(H*0.22,34,74)}px "Barlow Condensed",sans-serif`;
    const pillSize=clamp(H*0.088,16,32);
    const rowFont=`600 ${clamp(H*0.082,14,24)}px "Rajdhani",sans-serif`;
    const rowGap=clamp(H*0.03,8,14);

    const nameY=H*0.08;
    txt(fitText(tag,contentW,nameFont),contentX,nameY,"#ffffff",nameFont,"left");
    drawSep(contentX,nameY+fontPx(nameFont)+8,contentW,accent);

    const pillY=nameY+fontPx(nameFont)+18;
    drawStatusPill(contentX,pillY,sl,sc,pillSize);

    let rowY=pillY+drawStatusPillMetrics(sl,pillSize).height+16;
    const rows=getMetaRows(score,since,game,pres,accent).slice(0,4);

    rows.forEach(row=>{
      drawInfoRow(contentX,rowY,row.icon,row.text,row.color,rowFont,"left",contentW,row.iconColor);
      rowY+=fontPx(rowFont)+rowGap;
    });

    drawBadges(contentX,H-clamp(H*0.18,54,92),accent,contentW);
  }

  function draw(renderW:number=canvas.width, renderH:number=canvas.height){
    const W=renderW;
    const H=renderH;
    const tag=iTag.value.trim() || "YourGamertag";
    const score=Number(iScore.value || 0).toLocaleString();
    const game=iGame.value.trim();
    const since=iSince.value.trim();
    const status=(iStatus.value as Status) || "online";
    const sl=statusMap[status].label;
    const sc=statusMap[status].color;
    const pres=iPresence.value.trim();
    const accent=iAccent.value || selTheme.accent;

    ctx.clearRect(0,0,canvas.width,canvas.height);
    drawBg(W,H,accent);
    drawFrame(W,H,accent);

    if(selExport.id==="square") drawSquare(W,H,accent,sc,sl,tag,score,since,game,pres);
    else if(selExport.id==="story") drawStory(W,H,accent,sc,sl,tag,score,since,game,pres);
    else if(selExport.id==="banner") drawBanner(W,H,accent,sc,sl,tag,score,since,game,pres);
    else drawWide(W,H,accent,sc,sl,tag,score,since,game,pres);
  }

  document.getElementById("downloadBtn")!.addEventListener("click",()=>{
    const logicalW = selExport.width;
    const logicalH = selExport.height;
    const requestedScale = Number(iExportSc.value || 4);
    const scale = safeExportScale(requestedScale, logicalW, logicalH);

    canvas.width = logicalW * scale;
    canvas.height = logicalH * scale;
    applyCtxQuality();

    ctx.setTransform(scale,0,0,scale,0,0);
    draw(logicalW, logicalH);

    const link=document.createElement("a");
    link.download=`${iTag.value.trim() || "gamercard"}-${selExport.id}-${scale}x.png`;
    link.href=canvas.toDataURL("image/png");
    link.click();

    canvas.width = logicalW;
    canvas.height = logicalH;
    applyCtxQuality();
    ctx.setTransform(1,0,0,1,0,0);
    draw(logicalW, logicalH);
  });

  resizeCanvas();
  draw();
</script>
</MainLayout>