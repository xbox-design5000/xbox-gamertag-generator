          >
            Xbox Gamertag Availability Checker FAQ
          </h2>
          <p class="text-sm max-w-2xl mx-auto" style="font-family:'Inter',sans-serif; color: hsl(215 16% 47%); line-height: 1.6;">
            Common questions about checking Xbox gamertag availability.
          </p>
        </div>

        <div class="flex flex-col gap-3" id="faq-list-checker">
          {faqItems.map((item, index) => (
            <div
              class="faq-item-checker w-full overflow-hidden rounded-lg"
              style="background: #ffffff; border: 1px solid hsl(220 13% 91%); box-shadow: 0 2px 8px hsl(218 30% 9% / 0.06); transition: border-color 0.2s ease, box-shadow 0.2s ease;"
            >
              <button
                class="faq-toggle-checker w-full flex items-center justify-between gap-4 text-left px-5 py-4 sm:px-6 sm:py-5"
                type="button"
                aria-expanded="false"
                style="background: transparent; border: none; cursor: pointer; outline: none; touch-action: manipulation;"
              >
