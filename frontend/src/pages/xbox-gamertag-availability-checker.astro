                  <polyline points="6 9 12 15 18 9" />
                </svg>
              </button>
              <div class="faq-content-checker" style="max-height: 0; overflow: hidden; transition: max-height 0.35s cubic-bezier(0.4,0,0.2,1);">
                <div class="mx-5 sm:mx-6" style="height:1px; background: hsl(220 13% 91%);"></div>
                <div class="px-5 sm:px-6 py-4 sm:py-5">
                  <p class="text-sm leading-relaxed" style="font-family:'Inter',sans-serif; color: hsl(215 16% 47%); line-height: 1.75;">
                    {item.answer}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

 

  </div>
</MainLayout>

<style>
  .faq-item-checker:hover {
    border-color: hsl(107 76% 26% / 0.3) !important;
    box-shadow: 0 4px 16px hsl(218 30% 9% / 0.1) !important;
  }
  .faq-item-checker.is-open {
    border-color: hsl(107 76% 26% / 0.4) !important;
    box-shadow: 0 4px 20px hsl(218 30% 9% / 0.1) !important;
  }
  .faq-item-checker.is-open .faq-toggle-checker span {
    color: hsl(107 76% 26%) !important;
  }
  .faq-item-checker.is-open .faq-toggle-checker svg {
    transform: rotate(180deg);
  }
  .faq-toggle-checker:hover {
    background-color: hsl(220 13% 97%) !important;
  }
  @media (prefers-reduced-motion: reduce) {
    .faq-content-checker { transition: none !important; }
  }
</style>

<script>
  const API_BASE = import.meta.env.PUBLIC_API_URL ?? 'http://localhost:8000';

  const input    = document.getElementById('gamertag-input') as HTMLInputElement;
  const btn      = document.getElementById('check-btn') as HTMLButtonElement;
  const result   = document.getElementById('result')!;
  const inner    = document.getElementById('result-inner')!;
  const loading  = document.getElementById('loading')!;

  async function checkTag() {
    const tag = input.value.trim();
    if (!tag) return;

    result.classList.add('hidden');
    loading.classList.remove('hidden');
    btn.disabled = true;

    try {
      const res  = await fetch(`${API_BASE}/api/xbox/gametag/check`, {
        method:  'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body:    JSON.stringify({ gamertag: tag }),
      });
      const data = await res.json();

      loading.classList.add('hidden');
      result.classList.remove('hidden');

      if (data.error) {
        inner.innerHTML = errorHTML(data.message ?? 'Could not connect to Xbox API. Please try again.');
        return;
      }

      const isAvailable = data.available;
      inner.innerHTML   = isAvailable ? availableHTML(data.gamertag) : takenHTML(data.gamertag);

    } catch {
      loading.classList.add('hidden');
      result.classList.remove('hidden');
      inner.innerHTML = errorHTML('Network error. Please check your connection.');
    } finally {
      btn.disabled = false;
    }
  }

  function availableHTML(tag: string) {
    return `
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-[#00D02B]/10 border border-[#00D02B]/25 shrink-0">
          <svg class="w-6 h-6 text-[#00B324]" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </div>
        <div>
          <p class="text-[#111827] font-bold text-lg">${escHtml(tag)}</p>
          <p class="text-[#00B324] text-xs font-bold uppercase tracking-[0.16em] mt-1">Likely Available</p>
          <p class="text-[#6B7280] text-sm mt-1">No Xbox profile matched this gamertag. It may be free to claim.</p>
        </div>
      </div>
    `;
  }

  function takenHTML(tag: string) {
    return `
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-red-500/[0.08] border border-red-500/30 shrink-0">
          <svg class="w-6 h-6 text-red-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </div>
        <div>
          <p class="text-[#111827] font-bold text-lg">${escHtml(tag)}</p>
          <p class="text-red-500 text-xs font-bold uppercase tracking-[0.16em] mt-1">Taken</p>
          <p class="text-[#6B7280] text-sm mt-1">This gamertag is already registered to an Xbox account.</p>
        </div>
      </div>
    `;
  }

  function errorHTML(msg: string) {
    return `
      <div class="flex items-start gap-4">
        <div class="flex items-center justify-center w-12 h-12 rounded-full bg-yellow-500/[0.08] border border-yellow-500/30 shrink-0">
          <svg class="w-6 h-6 text-yellow-500" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/>
          </svg>
        </div>
        <div>
          <p class="font-bold text-yellow-600">Error</p>
          <p class="text-[#6B7280] text-sm mt-1">${escHtml(msg)}</p>
        </div>
      </div>
    `;
  }

  function escHtml(str: string) {
    return str.replace(/[&<>"']/g, c =>
      ({ '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]!));
  }

  btn.addEventListener('click', checkTag);
  input.addEventListener('keydown', e => { if (e.key === 'Enter') checkTag(); });

  // FAQ accordion
  function initFaqChecker() {
    document.querySelectorAll('.faq-toggle-checker').forEach(function(btn) {
      if ((btn as HTMLElement).dataset.bound === 'true') return;
      (btn as HTMLElement).dataset.bound = 'true';
      btn.addEventListener('click', function() {
        const item = (btn as HTMLElement).closest('.faq-item-checker');
        const content = item ? item.querySelector('.faq-content-checker') as HTMLElement : null;
        if (!item || !content) return;
        const isOpen = item.classList.contains('is-open');
        document.querySelectorAll('.faq-item-checker').forEach(function(el) {
          el.classList.remove('is-open');
          const c = el.querySelector('.faq-content-checker') as HTMLElement;
          if (c) c.style.maxHeight = '0';
          const t = el.querySelector('.faq-toggle-checker') as HTMLElement;
          if (t) t.setAttribute('aria-expanded', 'false');
        });
        if (!isOpen) {
          item.classList.add('is-open');
          content.style.maxHeight = content.scrollHeight + 'px';
          (btn as HTMLElement).setAttribute('aria-expanded', 'true');
        }
      });
    });
  }

  initFaqChecker();
  document.addEventListener('astro:page-load', initFaqChecker);
</script>