---
import MainLayout from "../layouts/MainLayout.astro";
import Header from "../components/layout/Header.astro";

const pageUrl = "https://xboxgamertaggenerator.com/gamertag-price-checker";

const faqItems = [
  {
    question: "What is an OG Xbox gamertag?",
    answer: "An OG gamertag is a short, clean, original name registered early on Xbox Live. These are usually one word, letters only, with no numbers or suffixes. They are rare and considered desirable by the Xbox community."
  },
  {
    question: "How much is a short Xbox gamertag worth?",
    answer: "Short gamertags — especially 3 to 5 characters — are considered more valuable because they are rare, clean, and hard to find available. The exact value depends on readability, format, and demand."
  },
  {
    question: "Can you sell an Xbox gamertag?",
    answer: "Selling Xbox gamertags may violate Microsoft Terms of Service. This tool is for informational purposes only and does not support the buying or selling of gamertags."
  },
  {
    question: "Is the price shown an official Xbox value?",
    answer: "No. The score is an estimate based on length, rarity, and readability. It is not an official Xbox or Microsoft valuation."
  },
  {
    question: "What gamertags are considered rare?",
    answer: "Gamertags are considered rare when they are very short, use letters only, contain a single recognizable word, or were registered in the early days of Xbox Live."
  }
];

const schema = {
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Xbox Gamertag Price Checker",
  "url": pageUrl,
  "description": "Estimate the value of your Xbox gamertag based on length, rarity, and readability. Free Xbox gamertag worth checker — enter any name and get an instant score.",
  "applicationCategory": "GameApplication",
  "operatingSystem": "Web",
  "inLanguage": "en-US",
  "isAccessibleForFree": true,
  "creator": {
    "@type": "Organization",
    "name": "Xbox Gamertag Generator",
    "url": "https://xboxgamertaggenerator.com"
  },
  "offers": {
    "@type": "Offer",
    "price": "0",
    "priceCurrency": "USD"
  },
  "potentialAction": {
    "@type": "UseAction",
    "target": pageUrl
  }
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map((item) => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer
    }
  }))
};
---

<MainLayout
  title="Xbox Gamertag Price Checker — How Much Is Your Gamertag Worth?"
  description="Estimate the value of your Xbox gamertag based on length, rarity, and readability. Free Xbox gamertag worth checker — enter any name and get an instant score."
  canonical={pageUrl}
  {schema}
>
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  <Header />

  <div class="min-h-screen bg-[#F3F4F6] font-ui text-[#111827]">

    <!-- ── Hero ── -->
    <section class="section-dark-alt py-8">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 xl:px-12">
        <div class="bg-card border border-default rounded-xl py-14 md:py-16 px-6 md:px-10 text-center shadow-card relative overflow-hidden">
          <div class="bg-hero-glow absolute inset-0 pointer-events-none"></div>

          <div class="relative z-10">
            <div class="inline-flex items-center gap-2 px-3 py-1 bg-brand-dim border border-green rounded-sm mb-6">
              <span class="label-green">Free Tool</span>
            </div>

            <h1 class="text-3xl md:text-4xl lg:text-5xl font-extrabold text-foreground mb-4 leading-tight">
              Xbox Gamertag <span class="text-brand">Price Checker</span>
            </h1>

            <p class="text-foreground-muted text-sm md:text-base max-w-2xl mx-auto leading-relaxed">
              The Xbox Gamertag Price Checker estimates the value of any Xbox gamertag based on length, rarity, readability, and format. Enter a gamertag below to get an instant score. Results are estimates for informational purposes only and are not official Xbox valuations.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Tool ── -->
    <section class="section-white-subtle py-10">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 space-y-5">

        <!-- Input Card -->
        <div class="bg-white border border-[#E5E7EB] rounded-xl p-6 md:p-7 shadow-lg">
          <label class="text-xs font-bold tracking-[0.18em] uppercase text-[#6B7280] block mb-3">
            Enter your Xbox Gamertag
          </label>

          <div class="flex flex-col sm:flex-row gap-3">
            <input
              id="gamertagInput"
              type="text"
              maxlength="12"
              placeholder="e.g. ShadowWolf"
              class="flex-1 px-4 py-3 bg-[#F8FAFC] border border-[#E5E7EB] rounded-lg text-[#111827] placeholder-[#9CA3AF] text-sm font-medium focus:outline-none focus:border-[#00D02B] focus:ring-2 focus:ring-[#00D02B]/15 transition-colors"
            />
            <button
              id="checkBtn"
              class="px-6 py-3 bg-brand hover:bg-brand-light text-white font-semibold text-sm uppercase tracking-[0.14em] rounded-lg transition-colors duration-200 whitespace-nowrap disabled:opacity-40 disabled:cursor-not-allowed"
            >
              Check Value
            </button>
          </div>

          <p class="text-xs text-[#9CA3AF] mt-2">
            Max 12 characters · Letters, numbers and spaces only
          </p>
          <p class="text-xs text-[#9CA3AF] mt-1 leading-relaxed">
            Tip: Short, clean tags often score higher. Premium-looking names often use strong letters
            like Z, X, V, K, or Y — but avoid too many numbers or old-style patterns like xX or underscores.
          </p>
        </div>

        <!-- Loading -->
        <div id="loadingState" class="hidden text-center py-12">
          <div
            class="inline-block w-8 h-8 rounded-full animate-spin mb-4"
            style="border: 2px solid #E5E7EB; border-top-color: #00D02B;"
          ></div>
          <p class="text-sm text-[#6B7280] tracking-wide">Analyzing your gamertag...</p>
        </div>

        <!-- Error -->
        <div id="errorState" class="hidden bg-red-500/[0.06] border border-red-500/30 rounded-xl p-6 text-center">
          <p id="errorMsg" class="text-sm font-bold text-red-500"></p>
        </div>

        <!-- Results -->
        <div id="results" class="hidden space-y-4">

          <!-- Tier + Price Card -->
          <div class="bg-white border border-[#E5E7EB] rounded-xl p-8 text-center shadow-lg">
            <p class="text-xs font-bold tracking-[0.16em] uppercase text-[#9CA3AF] mb-2">
              Estimated value for
            </p>
            <h2 id="resultTag" class="text-3xl md:text-4xl font-extrabold text-[#111827] mb-5"></h2>
            <div id="tierBadge" class="inline-flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold mb-6"></div>
            <div class="text-4xl md:text-5xl font-extrabold text-brand mb-2" id="priceRange"></div>
            <p class="text-xs text-[#9CA3AF] uppercase tracking-wider">Estimated market value</p>
          </div>

          <!-- Score Bar Card -->
          <div class="bg-white border border-[#E5E7EB] rounded-xl p-6 shadow-lg">
            <div class="flex items-center justify-between mb-3">
              <span class="text-xs font-bold tracking-[0.16em] uppercase text-[#6B7280]">Rarity Score</span>
              <span id="scoreValue" class="text-sm font-extrabold text-brand"></span>
            </div>
            <div class="w-full bg-[#E5E7EB] rounded-full h-3 overflow-hidden">
              <div id="scoreBar" class="h-3 rounded-full transition-all duration-700 ease-out" style="width: 0%"></div>
            </div>
            <div class="flex justify-between text-xs text-[#9CA3AF] mt-1.5">
              <span>0</span>
              <span>25</span>
              <span>50</span>
              <span>75</span>
              <span>100</span>
            </div>
          </div>

          <!-- Breakdown Card -->
          <div class="bg-white border border-[#E5E7EB] rounded-xl p-6 shadow-lg">
            <h3 class="text-sm font-bold text-[#111827] mb-5">Score Breakdown</h3>
            <div id="breakdownList" class="space-y-0"></div>
          </div>

          <!-- CTA — low score -->
          <div class="bg-white border border-[#E5E7EB] rounded-xl p-6 text-center shadow-lg">
            <p class="text-sm text-[#6B7280] mb-3 leading-relaxed">
              Score lower than expected? Use our
              <a href="/gamertag-optimizer" class="text-brand font-semibold underline underline-offset-2 hover:text-brand-light transition-colors duration-200">Gamertag Optimizer</a>
              to get cleaner, higher-scoring alternatives.
            </p>
          </div>

          <!-- Try Another -->
          <div class="text-center">
            <button
              id="resetBtn"
              class="px-6 py-3 bg-white border border-[#D1D5DB] hover:border-[#00D02B]/40 text-[#6B7280] hover:text-[#00B324] font-semibold text-sm uppercase tracking-[0.14em] rounded-lg transition-all duration-150"
            >
              Check Another Gamertag
            </button>
          </div>

          <!-- Disclaimer -->
          <p class="text-xs text-[#9CA3AF] text-center px-4 pb-4 leading-relaxed">
            This is an estimate for entertainment purposes only. Actual gamertag
            value depends on buyer demand and is not guaranteed. Selling Xbox
            gamertags may violate Microsoft's Terms of Service.
          </p>
        </div>

      </div>
    </section>

    <!-- Ad slot -->
    <section class="pb-10 section-white-subtle mt-2">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="bg-white border border-dashed border-[#D1D5DB] rounded-lg px-5 py-4 text-center">
          <p class="text-[10px] font-bold tracking-[3px] uppercase text-[#94A3B8] mb-3">Advertisement</p>
          <div class="bg-[#E5E7EB] rounded h-24 md:h-32"></div>
        </div>
      </div>
    </section>

    <!-- ── Article Sections ── -->
    <section
      class="pt-8 md:pt-16 pb-8"
      style="background-color: hsl(220 14% 96%); width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw;"
    >
      <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-12">

        <!-- H2-1: How It Works -->
          <section
  class="pt-8 md:pt-16 pb-8"
  style="background-color: #ffffff; width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw;"
>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 md:px-12">

        <div class="mb-12">
          <h2
            class="mt-6 mb-4"
            style="font-family: 'Inter', sans-serif; font-size: clamp(1.5rem, 3vw, 1.75rem); font-weight: 700; color: hsl(107 76% 26%); line-height: 1.2; letter-spacing: -0.02em;"
          >
            How the Xbox Gamertag Price Checker Works
          </h2>
          <p class="mb-4" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
            The tool analyzes the gamertag you enter and scores it based on several value factors. The higher the score, the more desirable the gamertag is likely to be in the gaming community.
          </p>
          <ol class="mb-0 space-y-2" style="list-style: decimal; padding-left: 1.5rem;">
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              Enter any Xbox gamertag in the field above
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              Click <strong style="color: #111827;">Check Value</strong> to run the analysis
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              View your gamertag score and value breakdown
            </li>
           <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
  If your score is low, try our <a href="/gamertag-optimizer" style="color: hsl(107 76% 26%); text-decoration: underline; font-weight: 600;">Gamertag Optimizer</a> to get cleaner, higher-scoring alternatives — or use our <a href="/" style="color: hsl(107 76% 26%); text-decoration: underline; font-weight: 600;">Xbox Gamertag Generator</a> to start fresh with a new name
</li>
          </ol>
        </div>

        <!-- H2-2: What Makes a Gamertag Valuable -->
        <div class="mb-12">
          <h2
            class="mt-6 mb-4"
            style="font-family: 'Inter', sans-serif; font-size: clamp(1.5rem, 3vw, 1.75rem); font-weight: 700; color: hsl(107 76% 26%); line-height: 1.2; letter-spacing: -0.02em;"
          >
       Xbox Gamertag Value — What Makes a Name Worth More
          </h2>
          <p class="mb-4" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
            Not all gamertags are equal in terms of desirability. Several factors affect how valuable or rare a gamertag is considered to be in the Xbox community.
          </p>
          <ul class="mb-0 space-y-2" style="list-style: disc; padding-left: 1.5rem;">
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Length</strong> — shorter names are rarer and harder to get. A 3-letter gamertag is far more valuable than a 12-letter one.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Letters only</strong> — names with no numbers look cleaner and are considered more desirable.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Readability</strong> — names that are easy to read, pronounce, and remember score higher.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Real words</strong> — dictionary words, single meaningful words, and clean one-word names hold more value.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">No symbols or underscores</strong> — clean formatting without special characters looks more professional.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Age and rarity</strong> — gamertags registered early on Xbox Live and never changed are considered OG.
            </li>
          </ul>
        </div>


        <!-- H2: How Much Is My Xbox Account Worth? -->
<div class="mb-12">
  <h2
    class="mt-6 mb-4"
    style="font-family: 'Inter', sans-serif; font-size: clamp(1.5rem, 3vw, 1.75rem); font-weight: 700; color: hsl(107 76% 26%); line-height: 1.2; letter-spacing: -0.02em;"
  >
    How Much Is My Xbox Account Worth?
  </h2>

  <p class="mb-4" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
    Xbox accounts accumulate value over time. Years of gameplay, achievements, rare gamertags, and game libraries all contribute to how desirable an account is. This tool estimates your gamertag value based on the name itself — but the full value of an Xbox account goes beyond just the name.
  </p>

  <p class="mb-6" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
    Here are the main factors that affect overall Xbox account value:
  </p>

  <div class="space-y-5">

    <div>
      <h3
        class="mb-2"
        style="font-family: 'Inter', sans-serif; font-size: clamp(1rem, 2.5vw, 1.15rem); font-weight: 700; color: #111827; line-height: 1.3;"
      >
        Gamertag Quality
      </h3>
      <p class="mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
        A short, clean, OG-style gamertag is one of the most valuable parts of an Xbox account. Names that are 3 to 5 characters, letters only, and have no number suffix are considered rare and desirable. This is what our price checker measures directly.
      </p>
    </div>

    <div>
      <h3
        class="mb-2"
        style="font-family: 'Inter', sans-serif; font-size: clamp(1rem, 2.5vw, 1.15rem); font-weight: 700; color: #111827; line-height: 1.3;"
      >
        Account Age
      </h3>
      <p class="mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
        Older accounts carry more credibility and history. An account registered in the early days of Xbox Live is worth more than a recently created one — both for the gamertag it holds and the legacy behind it.
      </p>
    </div>

    <div>
      <h3
        class="mb-2"
        style="font-family: 'Inter', sans-serif; font-size: clamp(1rem, 2.5vw, 1.15rem); font-weight: 700; color: #111827; line-height: 1.3;"
      >
        Gamerscore and Achievements
      </h3>
      <p class="mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
        A high Gamerscore shows years of active play and achievement completion. Accounts with thousands of achievements across many games are considered more established and hold more value in the gaming community.
      </p>
    </div>

    <div>
      <h3
        class="mb-2"
        style="font-family: 'Inter', sans-serif; font-size: clamp(1rem, 2.5vw, 1.15rem); font-weight: 700; color: #111827; line-height: 1.3;"
      >
        Number of Games
      </h3>
      <p class="mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
        A large game library adds depth to an account. The more games an account has — especially rare or older titles — the more history and value it carries overall.
      </p>
    </div>

  </div>

  <p class="mt-6 mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
    Note: This tool estimates gamertag value based on the name itself — length, rarity, and readability. It does not calculate full account value. Buying or selling Xbox accounts may violate Microsoft Terms of Service.
  </p>
</div>
        </div>
        </section>



        <!-- H2-3: What Is an OG Gamertag -->
        <div class="mb-12">
          <h2
            class="mt-6 mb-4"
            style="font-family: 'Inter', sans-serif; font-size: clamp(1.5rem, 3vw, 1.75rem); font-weight: 700; color: hsl(107 76% 26%); line-height: 1.2; letter-spacing: -0.02em;"
          >
            What Is an OG Xbox Gamertag?
          </h2>
          <p class="mb-4" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
            An OG gamertag is a short, clean, and original gamertag that was registered early on Xbox Live. OG stands for "original" and in the gaming community it refers to names that are simple, rare, and hard to get today. These are usually one word, letters only, and have no numbers or suffixes attached.
          </p>
          <p class="mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
            OG gamertags are considered desirable because they show the account has been active for a long time and the name was available before Xbox Live grew into a large platform. A 3-letter or 4-letter clean gamertag with no numbers is a classic example of an OG-style name.
          </p>
        </div>

        <!-- H2-4: Value Score Explained -->
        <div class="mb-0">
          <h2
            class="mt-6 mb-4"
            style="font-family: 'Inter', sans-serif; font-size: clamp(1.5rem, 3vw, 1.75rem); font-weight: 700; color: hsl(107 76% 26%); line-height: 1.2; letter-spacing: -0.02em;"
          >
            Xbox Gamertag Value Score Explained
          </h2>
          <p class="mb-4" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
            The value score this tool provides is based on a combination of the factors above. Here is a general guide to what each score level means:
          </p>
          <ul class="mb-4 space-y-2" style="list-style: disc; padding-left: 1.5rem;">
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Very High</strong> — ultra short, letters only, real word, no numbers. Very rare.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">High</strong> — short name, clean format, easy to read, no obvious issues.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Medium</strong> — decent length, minor formatting issues, readable but not exceptional.
            </li>
            <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
              <strong style="color: #111827;">Low</strong> — long name, random numbers, symbols, or hard-to-read formatting.
            </li>
          </ul>
          <p class="mb-0" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
            This score is an estimate for informational purposes only. It is not an official Xbox valuation and does not reflect actual market prices.
          </p>
        </div>

        <!-- H2-5: Tips for Improving Your Gamertag Value Score -->
<div class="mb-12">
  <h2
    class="mt-6 mb-4"
    style="font-family: 'Inter', sans-serif; font-size: clamp(1.5rem, 3vw, 1.75rem); font-weight: 700; color: hsl(107 76% 26%); line-height: 1.2; letter-spacing: -0.02em;"
  >
    Tips for Improving Your Gamertag Value Score
  </h2>

  <p class="mb-4" style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.8; color: #374151;">
    If your gamertag scored lower than expected, here are the most effective changes you can make to improve it.
  </p>

  <ul class="mb-0 space-y-3" style="list-style: disc; padding-left: 1.5rem;">
    <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
      <strong style="color: #111827;">Remove random numbers</strong> — numbers added just because a name was taken lower the score significantly. A clean name without numbers always scores higher.
    </li>
    <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
      <strong style="color: #111827;">Cut underscores and symbols</strong> — clean formatting without special characters scores better. Replace xX_Name_Xx with just the core word.
    </li>
    <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
      <strong style="color: #111827;">Shorten the name</strong> — the fewer characters the higher the rarity score. A 4 or 5 letter name will always score higher than a 12 character name.
    </li>
    <li style="font-family: 'Inter', sans-serif; font-size: clamp(15px, 2vw, 16px); line-height: 1.75; color: #374151;">
      <strong style="color: #111827;">Use real words</strong> — dictionary words and single meaningful words score higher than random letter combinations or made-up words.
    </li>
