  </div>

  <style>
    .faq-item-price:hover {
      border-color: hsl(107 76% 26% / 0.3) !important;
      box-shadow: 0 4px 16px hsl(218 30% 9% / 0.1) !important;
    }
    .faq-item-price.is-open {
      border-color: hsl(107 76% 26% / 0.4) !important;
      box-shadow: 0 4px 20px hsl(218 30% 9% / 0.1) !important;
    }
    .faq-item-price.is-open .faq-toggle-price span {
      color: hsl(107 76% 26%) !important;
    }
    .faq-item-price.is-open .faq-toggle-price svg {
      transform: rotate(180deg);
    }
    .faq-toggle-price:hover {
      background-color: hsl(220 13% 97%) !important;
    }
    @media (prefers-reduced-motion: reduce) {
      .faq-content-price { transition: none !important; }
    }
  </style>

  <script>
    const API_URL = import.meta.env.PUBLIC_API_URL ?? "http://localhost:8000";

    const input         = document.getElementById("gamertagInput")  as HTMLInputElement;
    const checkBtn      = document.getElementById("checkBtn")       as HTMLButtonElement;
    const resetBtn      = document.getElementById("resetBtn")       as HTMLButtonElement;
    const loadingState  = document.getElementById("loadingState")   as HTMLElement;
    const errorState    = document.getElementById("errorState")     as HTMLElement;
    const errorMsg      = document.getElementById("errorMsg")       as HTMLElement;
    const results       = document.getElementById("results")        as HTMLElement;
    const resultTag     = document.getElementById("resultTag")      as HTMLElement;
    const tierBadge     = document.getElementById("tierBadge")      as HTMLElement;
    const priceRange    = document.getElementById("priceRange")     as HTMLElement;
    const scoreValue    = document.getElementById("scoreValue")     as HTMLElement;
    const scoreBar      = document.getElementById("scoreBar")       as HTMLElement;
    const breakdownList = document.getElementById("breakdownList")  as HTMLElement;

    type Tier = "Legendary" | "Rare" | "Uncommon" | "Common" | "Low Value";

    const tierStyles: Record<Tier, { badge: string; bar: string }> = {
      "Legendary" : { badge: "bg-yellow-500/12 text-yellow-700 border border-yellow-500/25", bar: "bg-gradient-to-r from-yellow-500 to-yellow-300" },
      "Rare"      : { badge: "bg-purple-500/12 text-purple-700 border border-purple-500/25", bar: "bg-gradient-to-r from-purple-500 to-purple-400" },
      "Uncommon"  : { badge: "bg-blue-500/12 text-blue-700 border border-blue-500/25", bar: "bg-gradient-to-r from-blue-500 to-blue-400" },
      "Common"    : { badge: "bg-[#00D02B]/10 text-[#00B324] border border-[#00D02B]/25", bar: "bg-[#00D02B]" },
      "Low Value" : { badge: "bg-[#F3F4F6] text-[#6B7280] border border-[#E5E7EB]", bar: "bg-[#9CA3AF]" },
    };

    function showOnly(el: HTMLElement) {
      [loadingState, errorState, results].forEach((e) => e.classList.add("hidden"));
      el.classList.remove("hidden");
    }

    function resetTool() {
      [loadingState, errorState, results].forEach((e) => e.classList.add("hidden"));
      input.value = "";
      scoreBar.style.width = "0%";
      input.focus();
    }

    function renderResults(data: {
      gamertag  : string;
      score     : number;
      tier      : Tier;
      emoji     : string;
      priceRange: string;
      breakdown : { label: string; points: number; note: string }[];
    }) {
      const style = tierStyles[data.tier] ?? tierStyles["Low Value"];

      resultTag.textContent  = data.gamertag;
      priceRange.textContent = data.priceRange;
      scoreValue.textContent = `${data.score} / 100`;

      scoreBar.className = `h-3 rounded-full transition-all duration-700 ease-out ${style.bar}`;
      setTimeout(() => { scoreBar.style.width = `${data.score}%`; }, 100);

      tierBadge.className = `inline-flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold mb-6 ${style.badge}`;
      tierBadge.innerHTML = `${data.emoji} ${data.tier}`;

      breakdownList.innerHTML = data.breakdown.map((item) => `
        <div class="flex items-start justify-between py-3 border-b border-[#E5E7EB] last:border-0 gap-4">
          <div class="flex-1">
            <p class="text-sm font-bold text-[#111827]">${item.label}</p>
            <p class="text-xs text-[#9CA3AF] mt-0.5">${item.note}</p>
          </div>
          <span class="text-xs font-bold shrink-0 ${item.points > 0 ? "text-[#00B324]" : item.points < 0 ? "text-red-500" : "text-[#9CA3AF]"}">
            ${item.points > 0 ? "+" : ""}${item.points} pts
          </span>
        </div>`
      ).join("");
    }

    async function checkPrice() {
      const tag = input.value.trim();

      if (!tag) {
        errorMsg.textContent = "Please enter a gamertag first.";
        showOnly(errorState);
        return;
      }

      showOnly(loadingState);
      checkBtn.disabled = true;

      try {
        const res = await fetch(`${API_URL}/api/check-price`, {
          method : "POST",
          headers: { "Content-Type": "application/json", "Accept": "application/json" },
          body: JSON.stringify({ gamertag: tag }),
        });

        if (!res.ok) {
          const err = await res.json().catch(() => ({}));
          throw new Error(err?.message ?? `Server error (${res.status}). Please try again.`);
        }

        const data = await res.json();
        renderResults(data);
        showOnly(results);
      } catch (err: any) {
        errorMsg.textContent = err.message ?? "Something went wrong. Please try again.";
        showOnly(errorState);
      } finally {
        checkBtn.disabled = false;
      }
    }

    checkBtn.addEventListener("click", checkPrice);
    resetBtn.addEventListener("click", resetTool);
    input.addEventListener("keydown", (e) => { if (e.key === "Enter") checkPrice(); });

    // FAQ accordion
    function initFaqPrice() {
      document.querySelectorAll('.faq-toggle-price').forEach(function(btn) {
        if ((btn as HTMLElement).dataset.bound === 'true') return;
        (btn as HTMLElement).dataset.bound = 'true';
        btn.addEventListener('click', function() {
          const item = (btn as HTMLElement).closest('.faq-item-price');
          const content = item ? item.querySelector('.faq-content-price') as HTMLElement : null;
          if (!item || !content) return;
          const isOpen = item.classList.contains('is-open');
          document.querySelectorAll('.faq-item-price').forEach(function(el) {
            el.classList.remove('is-open');
            const c = el.querySelector('.faq-content-price') as HTMLElement;
            if (c) c.style.maxHeight = '0';
            const t = el.querySelector('.faq-toggle-price') as HTMLElement;
            if (t) t.setAttribute('aria-expanded', 'false');
          });
          if (!isOpen) {
            item.classList.add('is-open');
            content.style.maxHeight = content.scrollHeight + 'px';
            (btn as HTMLElement).setAttribute('aria-expanded', 'true');
          }
        });
      });
    }

    initFaqPrice();
    document.addEventListener('astro:page-load', initFaqPrice);
  </script>
</MainLayout>