---
import Search from "@lucide/astro/icons/search";
import BarChart3 from "@lucide/astro/icons/chart-column";
import Download from "@lucide/astro/icons/download";
import DollarSign from "@lucide/astro/icons/dollar-sign";
import UserCheck from "@lucide/astro/icons/user-check";
import Gift from "@lucide/astro/icons/gift";
import Sparkles from "@lucide/astro/icons/sparkles";

type Tool = {
  id: string;
  title: string;
  description: string;
  icon: typeof Search;
  slug: string;
  anchor: string;
  comingSoon?: boolean;
};

const tools: Tool[] = [
  {
    id: "1",
    title: "Xbox Gamertag Generator",
    description: "Generate cool, funny, short, and unique Xbox gamertag ideas instantly.",
    slug: "/",
    anchor: "generate Xbox gamertag ideas",
    icon: UserCheck,
  },
  {
    id: "2",
    title: "Xbox Gamertag Availability Checker",
    description: "Check whether an Xbox gamertag may be available or already taken.",
    icon: Search,
    slug: "xbox-gamertag-availability-checker",
    anchor: "check Xbox gamertag availability",
  },
  {
    id: "3",
    title: "Xbox Gamertag Search",
    description: "Look up public Xbox profile details, Gamerscore, and game activity by gamertag.",
    icon: BarChart3,
    slug: "xbox-gamertag-search",
    anchor: "search an Xbox profile by gamertag",
  },
  {
    id: "4",
    title: "Xbox Gamercard Generator",
    description: "Create a custom Xbox-style profile card with your gamertag, avatar, and Gamerscore.",
    icon: Gift,
    slug: "gamercard-generator",
    anchor: "create a custom Xbox gamercard",
  },
  {
    id: "5",
    title: "Xbox Gamertag Price Checker",
    description: "Estimate whether a gamertag may be rare, short, or potentially valuable.",
    icon: DollarSign,
    slug: "gamertag-price-checker",
    anchor: "estimate your Xbox gamertag value",
  },
  {
    id: "6",
    title: "Xbox Gamertag Optimizer",
    description: "Shorten, clean, and rewrite weak or messy Xbox gamertags into better options.",
    icon: Sparkles,
    slug: "gamertag-optimizer",
    anchor: "optimize your Xbox gamertag",
  },
];

const getToolLink = (slug: string): string => {
  if (slug === "/") return "/";
  const map: Record<string, string> = {
    "xbox-gamertag-availability-checker": "/xbox-gamertag-availability-checker",
    "xbox-gamertag-search": "/xbox-gamertag-search",
    "gamercard-generator": "/gamercard-generator",
    "gamertag-price-checker": "/gamertag-price-checker",
    "gamertag-optimizer": "/gamertag-optimizer",
  };
  return map[slug] ?? `/${slug}`;
};
---

<section class="section-white-subtle py-16 md:py-20">
  <div class="max-w-5xl mx-auto px-6">

    <!-- Header -->
    <div class="text-center mb-12">
      <h2 class="heading-section text-brand mb-3">
        Related Xbox Gamertag Tools
      </h2>
      <p class="text-sm md:text-base font-ui leading-relaxed max-w-2xl mx-auto" style="color: hsl(215 16% 47%);">
        After using this tool, explore our other free Xbox tools to complete your gaming identity.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {tools.map((tool) => {
        const Icon = tool.icon;
        const href = getToolLink(tool.slug);

        return (
          <div
            class:list={[
              "bg-white rounded-xl p-6 transition-shadow duration-200 group relative flex flex-col h-full",
              tool.comingSoon ? "opacity-95" : "hover:shadow-xl"
            ]}
          >
            {tool.comingSoon && (
              <div class="absolute top-4 right-4 bg-brand text-white text-xs px-2 py-1 rounded-full font-ui">
                Coming Soon
              </div>
            )}

            <div class="text-brand mb-4">
              <Icon class="h-10 w-10" />
            </div>

            <h3 class="text-xl font-semibold mb-3 text-[#1F2937] group-hover:text-brand transition-colors font-ui leading-snug">
              {tool.title}
            </h3>

            <p class="text-[#4B5563] mb-4 font-ui leading-7">
              {tool.description}
            </p>

            <div class="mt-auto">
              {tool.comingSoon ? (
                <button
                  disabled
                  class="bg-[#D1D5DB] text-[#6B7280] px-4 py-2 rounded font-ui cursor-not-allowed w-full sm:w-auto"
                >
                  Coming Soon
                </button>
              ) : (
                <a
                  href={href}
                class="inline-block bg-brand hover:bg-brand-light text-white px-4 py-2 rounded transition-colors font-ui w-full text-center sm:w-auto text-sm whitespace-nowrap"
                >
                  {tool.anchor}
                </a>
              )}
            </div>
          </div>
        );
      })}
    </div>

    <!-- Ad slot -->
    <div class="bg-[#F3F4F6] rounded-lg px-4 md:px-6 py-6 text-center border-2 border-dashed border-[#D1D5DB] mt-8">
      <p class="text-sm md:text-base text-[#6B7280] mb-2 font-ui">Advertisement</p>
      <div class="h-20 md:h-32 lg:h-40 bg-[#E5E7EB] rounded"></div>
    </div>

  </div>
</section>