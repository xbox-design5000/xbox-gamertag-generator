---
import { blogPosts } from "../../data/blogPosts";

const featuredPosts = blogPosts.slice(0, 6);
---

<!-- Full-width light grey — matches ReactJS bg-light-grey -->
<section
  class=" pb-16"
  style="background-color: hsl(220 14% 96%); width: 100vw; position: relative; left: 50%; right: 50%; margin-left: -50vw; margin-right: -50vw;"
>
  <div class="max-w-5xl mx-auto px-6">

    <!-- Heading — matches ReactJS text-3xl font-bebas text-xbox-green text-center mb-12 -->
    <h2
      class="text-center mb-12"
      style="font-family: 'Inter', sans-serif; font-size: clamp(1.6rem, 3vw, 1.875rem); font-weight: 700; color: hsl(107 76% 26%); letter-spacing: -0.02em; line-height: 1.2;"
    >
      Featured Gaming Guides
    </h2>

    <!-- Blog grid — matches ReactJS grid md:grid-cols-2 lg:grid-cols-3 gap-8 -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {featuredPosts.map((post) => (
        <article class="blog-card bg-white rounded-xl overflow-hidden"
                 style="box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);">
          <div class="p-6">

            <!-- Title — matches ReactJS text-xl font-semibold text-gray-800 group-hover:text-xbox-green -->
            <h3
              class="blog-card-title mb-3"
              style="font-family: 'Inter', sans-serif; font-size: 1.125rem; font-weight: 600; color: #1f2937; line-height: 1.4; transition: color 0.2s ease;"
            >
              {post.title}
            </h3>

            <!-- Excerpt — matches ReactJS text-gray-600 mb-4 line-clamp-3 -->
            <p
              class="line-clamp-3 mb-4"
              style="font-family: 'Inter', sans-serif; font-size: 0.9rem; color: #4b5563; line-height: 1.6;"
            >
              {post.excerpt}
            </p>

            <!-- Footer row — clock + read more -->
            <div class="flex items-center justify-between">

              <!-- Clock + read time — matches ReactJS text-sm text-gray-500 -->
              <div class="flex items-center gap-1" style="color: #6b7280;">
                <!-- Clock icon — matches ReactJS Clock h-4 w-4 -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
                <span style="font-family: 'Inter', sans-serif; font-size: 0.875rem;">{post.readTime}</span>
              </div>

              <!-- Read More — matches ReactJS text-xbox-green font-medium inline-flex items-center -->
              <a
                href={`/${post.slug}`}
                class="blog-read-more inline-flex items-center gap-1"
                style="font-family: 'Inter', sans-serif; font-size: 0.875rem; font-weight: 500; color: hsl(107 76% 26%); text-decoration: none; transition: transform 0.15s ease, color 0.15s ease;"
              >
                Read More
                <!-- ArrowRight h-4 w-4 -->
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>

            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- View All CTA — matches ReactJS bg-xbox-green hover:bg-xbox-green-light text-white font-semibold rounded-lg -->
    <div class="text-center mt-12">
      <a
        href="/blog"
        class="blog-cta inline-flex items-center gap-2 px-6 py-3 rounded-lg font-semibold transition-colors duration-200"
        style="background-color: hsl(107 76% 26%); color: #ffffff; font-family: 'Inter', sans-serif; font-size: 0.9rem; text-decoration: none;"
      >
        View All Posts
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"/>
          <polyline points="12 5 19 12 12 19"/>
        </svg>
      </a>
    </div>

    <!-- Ad Banner — matches ReactJS bg-gray-100 border-dashed border-gray-300 -->
    <div class="rounded-lg px-4 md:px-6 py-6 text-center mt-8"
         style="background: #f3f4f6; border: 2px dashed #d1d5db;">
      <p class="text-xs md:text-sm mb-2"
         style="color: #6b7280; font-family: 'Inter', sans-serif;">Advertisement</p>
      <div class="rounded h-20 md:h-32 lg:h-40" style="background: #e5e7eb;"></div>
    </div>

  </div>
</section>

<style>
  /* Card hover — matches ReactJS hover:shadow-lg transition-shadow group */
  .blog-card {
    transition: box-shadow 0.2s ease;
  }
  .blog-card:hover {
    box-shadow: 0 10px 15px -3px rgb(0 0 0 / 0.1), 0 4px 6px -4px rgb(0 0 0 / 0.1) !important;
  }

  /* Title turns green on card hover — matches ReactJS group-hover:text-xbox-green */
  .blog-card:hover .blog-card-title {
    color: hsl(107 76% 26%) !important;
  }

  /* Read More arrow shifts right on card hover — matches ReactJS group-hover:translate-x-1 */
  .blog-card:hover .blog-read-more {
    transform: translateX(4px);
  }

  /* CTA button hover */
  .blog-cta:hover {
    background-color: hsl(107 76% 34%) !important;
  }

  /* Disable hover transforms on touch devices */
  @media (pointer: coarse) {
    .blog-card:hover { box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1) !important; }
    .blog-card:hover .blog-read-more { transform: none; }
  }
</style>