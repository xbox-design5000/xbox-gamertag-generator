---
import { urlFor } from "../../lib/sanity";

interface SocialLink {
  platform: string;
  url: string;
}

interface Props {
  author: {
    name: string;
    slug: string;
    bio?: string;
    photo?: any;
    role?: string;
    socialLinks?: SocialLink[];
  };
}

const { author } = Astro.props;

const photoUrl = author.photo
  ? urlFor(author.photo).width(80).height(80).fit('crop').auto('format').url()
  : null;

