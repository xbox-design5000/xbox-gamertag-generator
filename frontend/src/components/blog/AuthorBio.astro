---

<div class="flex items-start gap-4 p-5 rounded-xl bg-white-subtle border border-white-border">
  {photoUrl ? (
    <img
      src={photoUrl}
      alt={author.name}
      class="w-14 h-14 rounded-full object-cover flex-shrink-0 border-2 border-white shadow-sm"
    />
  ) : (
    <div class="w-14 h-14 rounded-full bg-gray-200 flex items-center justify-center flex-shrink-0">
      <svg class="h-6 w-6 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5.121 17.804A10.966 10.966 0 0112 15c2.125 0 4.109.602 5.879 1.804M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
      </svg>
    </div>
  )}

  <div class="flex-1 min-w-0">
    <p class="text-xs font-bold tracking-widest uppercase mb-1 text-brand">Written by</p>
    
     <a href={`/author/${author.slug}`}
      class="text-sm font-bold text-dark-heading hover:text-brand transition-colors"
    >
      {author.name}
    </a>
    {author.role && (
      <p class="text-xs text-brand font-medium mt-0.5">{author.role}</p>
    )}
    {author.bio && (
      <p class="text-xs text-dark-body mt-1.5 leading-relaxed">{author.bio}</p>
    )}

    <div class="flex items-center gap-3 mt-3 flex-wrap">
      
      <a  href={`/author/${author.slug}`}
        class="inline-flex items-center gap-1 text-xs font-semibold text-brand hover:underline"
      >
        View all articles
        <svg class="h-3 w-3" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>

      {author.socialLinks && author.socialLinks.length > 0 && (
        <div class="flex items-center gap-2">
          {author.socialLinks.map((link) => (
            
              <a href={link.url}
              target="_blank"
              rel="noopener noreferrer"
              class="text-gray-400 hover:text-brand transition-colors"
              title={link.platform}
              set:html={socialIcons[link.platform] || socialIcons['Website']}
            />
          ))}
        </div>
      )}
    </div>
  </div>
</div>