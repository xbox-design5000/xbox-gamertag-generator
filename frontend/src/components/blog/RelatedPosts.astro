---
import { urlFor } from "../../lib/sanity";

interface RelatedPost {
  title: string;
  slug: string;
  excerpt: string;
  publishedAt: string;
  readingTime?: number;
  featuredImage?: any;
}

interface Props {
  posts: RelatedPost[];
}

const { posts } = Astro.props;
---

{posts && posts.length > 0 ? (
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    {posts.map((post) => {
      const imageUrl = post.featuredImage?.asset?._ref
        ? urlFor(post.featuredImage).width(400).height(250).fit('crop').auto('format').url()
        : null;

      return (
        
         <a href={`/${post.slug}`}
          class="bg-gray-50 rounded-lg overflow-hidden border border-gray-200 hover:shadow-md transition-shadow group"
        >
          <!-- Image -->
          <div class="w-full h-40 overflow-hidden bg-gray-200 flex-shrink-0">
            {imageUrl
              ? <img
                  src={imageUrl}
                  alt={post.title}
                  class="w-full h-full object-cover object-center group-hover:scale-105 transition-transform duration-300"
                />
              : <div class="w-full h-full bg-gradient-to-br from-gray-200 to-gray-300 flex items-center justify-center">
                  <svg class="h-8 w-8 text-gray-400" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                  </svg>
                </div>
            }
          </div>

          <!-- Content -->
          <div class="p-4">
            <h3 class="text-sm font-semibold text-gray-800 line-clamp-2 group-hover:text-brand transition-colors mb-2">
              {post.title}
            </h3>
            {post.excerpt && (
              <p class="text-xs text-gray-500 line-clamp-2 mb-3">
                {post.excerpt}
              </p>
            )}
            <div class="flex items-center gap-3 text-xs text-gray-400">
              {post.publishedAt && (
                <span>
                  {new Date(post.publishedAt).toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric'
                  })}
                </span>
              )}
              {post.readingTime && (
                <span>{post.readingTime} min read</span>
              )}
            </div>
          </div>
        </a>
      );
    })}
  </div>
) : (
  <p class="text-sm text-gray-500">More articles coming soon.</p>
)}